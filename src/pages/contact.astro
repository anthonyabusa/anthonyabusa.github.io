---
import BaseLayout from '../layouts/BaseLayout.astro';
import SocialLinks from '../components/SocialLinks.astro';

const contactLinks = [
  {
    label: 'Email',
    value: 'anthonyabusa@gmail.com',
    href: 'mailto:anthonyabusa@gmail.com',
    description: 'Best for detailed project inquiries or introductions.',
    icon: `<svg aria-hidden="true" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`,
  },
  {
    label: 'LinkedIn',
    value: 'linkedin.com/in/anthonyabusa',
    href: 'https://linkedin.com/in/anthonyabusa',
    description: 'Connect professionally or send a message.',
    icon: `<svg aria-hidden="true" width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  },
  {
    label: 'GitHub',
    value: 'github.com/anthonyabusa',
    href: 'https://github.com/anthonyabusa',
    description: "See what I'm building and contributing to.",
    icon: `<svg aria-hidden="true" width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>`,
  },
];
---

<BaseLayout
  title="Contact"
  description="Get in touch with Anthony Busa; for consulting inquiries, collaboration, or just a conversation."
>
  <div class="max-w-5xl mx-auto px-6 pt-32 pb-24">

    <div class="reveal max-w-2xl mb-16">
      <p class="text-accent font-mono text-xs tracking-widest uppercase mb-4">Get in Touch</p>
      <h1 class="text-4xl md:text-5xl font-bold text-ink mb-6 leading-tight">
        Let's talk.
      </h1>
      <p class="text-ink-muted text-lg leading-relaxed">
        I'm open to consulting engagements, co-founder conversations, and interesting ideas. If you're building something ambitious, reach out.
      </p>
    </div>

    <!-- Contact cards -->
    <div class="reveal-group grid sm:grid-cols-3 gap-5 mb-20">
      {contactLinks.map((link) => (
        <a
          href={link.href}
          target={link.href.startsWith('mailto') ? undefined : '_blank'}
          rel={link.href.startsWith('mailto') ? undefined : 'noopener noreferrer'}
          class="reveal group flex flex-col gap-4 p-6 rounded-xl border border-border bg-surface card-hover"
        >
          <div class="text-ink-subtle group-hover:text-accent-lighter transition-colors" set:html={link.icon} />
          <div>
            <p class="text-ink font-semibold text-sm mb-1">{link.label}</p>
            <p class="text-ink-faint text-xs font-mono truncate">{link.value}</p>
          </div>
          <p class="text-ink-muted text-xs leading-relaxed mt-auto">{link.description}</p>
        </a>
      ))}
    </div>

    <!-- Availability note -->
    <div class="reveal p-8 rounded-2xl border border-border bg-surface">
      {/* Live-status pattern (#383): dot + mono-uppercase label, shared with the
          ProjectCard "Live" chip; green = personal availability, amber = an
          operated system. motion-safe keeps the pulse off under reduced motion. */}
      <div class="flex items-center gap-2 mb-3">
        <span class="w-2 h-2 rounded-full bg-green-400 motion-safe:animate-pulse" />
        <span class="text-xs text-green-400 font-mono uppercase tracking-widest">Available</span>
      </div>
      <h2 class="text-ink font-semibold text-lg mb-2">Currently open to:</h2>
      <ul class="contact-list text-ink-muted text-sm space-y-1.5">
        <li>Consulting engagements (strategy, product, AI)</li>
        <li>Advisory roles with early-stage startups</li>
        <li>Co-founder conversations</li>
        <li>Speaking or podcast appearances</li>
      </ul>
    </div>

  </div>
</BaseLayout>

<style>
  .contact-list { list-style: none; padding-left: 0; }
  .contact-list li { position: relative; padding-left: 1.25rem; }
  .contact-list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: #818CF8;
  }
</style>
