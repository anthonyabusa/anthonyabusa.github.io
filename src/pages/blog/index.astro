---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogPostCard from '../../components/BlogPostCard.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const sorted = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Writing"
  description="Essays, reflections, and ideas from Anthony Busa on business, technology, and building things."
>
  <div class="max-w-5xl mx-auto px-6 pt-32 pb-24">

    <div class="reveal mb-14">
      <p class="text-[#6366F1] font-mono text-xs tracking-widest uppercase mb-4">Writing</p>
      <h1 class="text-4xl md:text-5xl font-bold text-[#F1F5F9] mb-4">Ideas & Essays</h1>
      <p class="text-[#64748B] max-w-lg">
        Thinking out loud on business strategy, technology, and what it takes to build things that last.
      </p>
    </div>

    {sorted.length === 0 ? (
      <p class="text-[#475569] text-sm">No posts yet; check back soon.</p>
    ) : (
      <div class="reveal-group grid sm:grid-cols-2 gap-6">
        {sorted.map((post) => (
          <BlogPostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
            slug={post.id}
          />
        ))}
      </div>
    )}

  </div>
</BaseLayout>
