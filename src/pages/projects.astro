---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import rawProjects from '../data/projects.json';

interface Project {
  title: string;
  description: string;
  url: string;
  liveUrl: string;
  tags: string[];
  featured: boolean;
  year: number;
  type: string;
}

const projects = (rawProjects as Project[]).sort((a, b) => {
  if (a.featured !== b.featured) return a.featured ? -1 : 1;
  return b.year - a.year;
});

const allTags = [...new Set(projects.flatMap((p) => p.tags))].sort();
---

<BaseLayout
  title="Projects"
  description="Active ventures, AI infrastructure, automation systems, and public proof-of-work by Anthony Abusa."
>
  <div class="max-w-5xl mx-auto px-6 pt-32 pb-24">

    <div class="reveal mb-14">
      <p class="text-[#6366F1] font-mono text-xs tracking-widest uppercase mb-4">Portfolio</p>
      <h1 class="text-4xl md:text-5xl font-bold text-[#F1F5F9] mb-4">Projects</h1>
      <p class="text-[#64748B] max-w-lg">
        Active ventures, infrastructure, and automation systems — the work I'm operating, not just the work I finished.
      </p>
    </div>

    <!-- Tag filter (visual only — all shown by default) -->
    <div class="reveal flex flex-wrap gap-2 mb-10">
      {allTags.map((tag) => (
        <span class="tag cursor-default">{tag}</span>
      ))}
    </div>

    <div class="reveal-group grid sm:grid-cols-2 md:grid-cols-3 gap-6">
      {projects.map((project) => (
        <ProjectCard {...project} liveUrl={project.liveUrl || undefined} />
      ))}
    </div>

  </div>
</BaseLayout>
