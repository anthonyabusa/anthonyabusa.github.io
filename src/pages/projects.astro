---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import rawProjects from '../data/projects.json';
import { focusAreas } from '../data/focusAreas';

const projects = rawProjects.filter((project) => project.placement !== 'experience').sort((a, b) => {
  if (a.featured !== b.featured) return a.featured ? -1 : 1;
  return (Number(b.year) || 0) - (Number(a.year) || 0);
});

// Discovery is driven by the canonical focus areas (same taxonomy as About and /work/*),
// not a hand-picked array. A chip shows only when a visible project actually carries that
// focus area, so every filter resolves to real cards instead of an empty grid (#382).
const present = new Set(projects.flatMap((project) => project.focusAreas ?? []));
const filters = focusAreas.filter((area) => present.has(area.slug));
---

<BaseLayout title="Projects" description="Active ventures, AI infrastructure, automation systems, and public proof-of-work by Anthony Busa.">
  <div class="max-w-5xl mx-auto px-6 pt-32 pb-24">
    <div class="reveal mb-14">
      <h1 class="text-4xl md:text-5xl font-bold text-ink mb-4">Projects</h1>
      <p class="text-accent font-mono text-xs tracking-widest uppercase mb-4">Portfolio</p>
      <p class="text-ink-muted max-w-lg">Active ventures, infrastructure, and automation systems. These are systems I operate, not just projects I finished.</p>
    </div>

    <div class="reveal flex flex-wrap gap-2 mb-10" aria-label="Filter projects">
      <button class="project-filter active" data-filter="all">All</button>
      {filters.map((area) => <button class="project-filter" data-filter={area.slug}>{area.title}</button>)}
    </div>

    <div class="reveal-group grid sm:grid-cols-2 md:grid-cols-3 gap-6">
      {projects.map((project) => (
        <div data-project-tags={(project.focusAreas ?? []).join(' ')}>
          <ProjectCard {...project} liveUrl={project.liveUrl || undefined} />
        </div>
      ))}
    </div>
  </div>
</BaseLayout>

<script>
  const filters = document.querySelectorAll<HTMLButtonElement>('[data-filter]');
  const cards = document.querySelectorAll<HTMLElement>('[data-project-tags]');
  filters.forEach((button) => button.addEventListener('click', () => {
    filters.forEach((item) => item.classList.remove('active'));
    button.classList.add('active');
    const selected = button.dataset.filter ?? '';
    cards.forEach((card) => {
      const tags = (card.dataset.projectTags ?? '').split(' ').filter(Boolean);
      card.hidden = selected !== 'all' && !tags.includes(selected);
    });
  }));
</script>
