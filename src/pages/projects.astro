---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import rawProjects from '../data/projects.json';

const projects = rawProjects.filter((project) => project.placement !== 'experience').sort((a, b) => {
  if (a.featured !== b.featured) return a.featured ? -1 : 1;
  return (Number(b.year) || 0) - (Number(a.year) || 0);
});
const filters = ['AI', 'Startup', 'Strategy', 'Operations'];
---

<BaseLayout title="Projects" description="Active ventures, AI infrastructure, automation systems, and public proof-of-work by Anthony Abusa.">
  <div class="max-w-5xl mx-auto px-6 pt-32 pb-24">
    <div class="reveal mb-14">
      <h1 class="text-4xl md:text-5xl font-bold text-[#F1F5F9] mb-4">Projects</h1>
      <p class="text-[#6366F1] font-mono text-xs tracking-widest uppercase mb-4">Portfolio</p>
      <p class="text-[#64748B] max-w-lg">Active ventures, infrastructure, and automation systems — the work I'm operating, not just the work I finished.</p>
    </div>

    <div class="reveal flex flex-wrap gap-2 mb-10" aria-label="Filter projects">
      <button class="project-filter active" data-filter="all">All</button>
      {filters.map((filter) => <button class="project-filter" data-filter={filter.toLowerCase()}>{filter}</button>)}
    </div>

    <div class="reveal-group grid sm:grid-cols-2 md:grid-cols-3 gap-6">
      {projects.map((project) => (
        <div data-project-tags={[project.status, ...project.tags].join(' ').toLowerCase()}>
          <ProjectCard {...project} liveUrl={project.liveUrl || undefined} />
        </div>
      ))}
    </div>
  </div>
</BaseLayout>

<script>
  const filters = document.querySelectorAll<HTMLButtonElement>('[data-filter]');
  const cards = document.querySelectorAll<HTMLElement>('[data-project-tags]');
  filters.forEach((button) => button.addEventListener('click', () => {
    filters.forEach((item) => item.classList.remove('active'));
    button.classList.add('active');
    cards.forEach((card) => {
      card.hidden = button.dataset.filter !== 'all' && !card.dataset.projectTags?.includes(button.dataset.filter ?? '');
    });
  }));
</script>
