---
import BaseLayout from '../layouts/BaseLayout.astro';

const demos = [
  {
    key: 'strategy',
    mark: '/->',
    title: 'Strategy',
    subtitle: 'Choose the path',
    note: 'Market shape, positioning, tradeoffs, and where effort should go.',
    concrete: ['market map', 'positioning', 'decision logic'],
  },
  {
    key: 'operations',
    mark: '[::]',
    title: 'Operations',
    subtitle: 'Make the system run',
    note: 'Workflows, metrics, handoffs, cadence, and execution rhythms.',
    concrete: ['process rhythm', 'KPI loops', 'throughput'],
  },
  {
    key: 'product',
    mark: '{<>}',
    title: 'Product / Program',
    subtitle: 'Turn ambiguity into releases',
    note: 'Roadmaps, scoped work, feedback loops, and repeatable delivery.',
    concrete: ['roadmap', 'scope', 'release loop'],
  },
  {
    key: 'automation',
    mark: '>*_',
    title: 'AI Automation',
    subtitle: 'Reduce operational drag',
    note: 'Agents, memory, queues, analytics, and useful automated action.',
    concrete: ['agent mesh', 'memory', 'evaluation'],
  },
  {
    key: 'marketplace',
    mark: '&lt;=&gt;',
    title: 'Marketplace',
    subtitle: 'Balance both sides',
    note: 'Producer supply, buyer demand, hubs, incentives, and local growth loops.',
    concrete: ['supply', 'demand', 'exchange'],
  },
];
---

<BaseLayout
  title="ASCII Motion Lab"
  description="Interactive ASCII motion directions for Anthony Busa's portfolio symbol and graphics system."
>
  <section class="max-w-6xl mx-auto px-6 pt-32 pb-24">
    <div class="max-w-3xl mb-12">
      <p class="text-[#6366F1] font-mono text-xs tracking-widest uppercase mb-4">Visual system spike</p>
      <h1 class="text-4xl md:text-6xl font-bold text-[#F1F5F9] leading-tight mb-5">ASCII motion lab</h1>
      <p class="text-[#94A3B8] text-lg leading-relaxed">
        The hero field is close. This version keeps the card copy concrete, while the animation layer becomes mostly wordless: visual sigils, orbiting fields, pulses, and abstract motion that supports rather than explains.
      </p>
    </div>

    <div class="ascii-stage mb-10" data-ascii-stage>
      <div class="ascii-stage__copy">
        <span class="ascii-stage__eyebrow">hero candidate</span>
        <h2>systems in motion</h2>
        <p>Move your cursor through the field. The signal follows, but stays quiet enough to sit behind real copy.</p>
      </div>
      <pre class="ascii-stage__field" data-ascii-field aria-hidden="true">+------------------------------------------------+
| strategy      ops      agents      market      |
|                                                |
|    . . .      . . .      . . .      . . .      |
|      \          |          |          /        |
|       +---------+----------+---------+         |
|                 signal: idle                   |
+------------------------------------------------+</pre>
    </div>

    <div class="grid md:grid-cols-2 xl:grid-cols-3 gap-5">
      {demos.map((demo) => (
        <button class={`ascii-demo ascii-demo--${demo.key}`} type="button" data-ascii-demo={demo.key} aria-label={`${demo.title}: ${demo.note}`}>
          <span class="ascii-demo__header">
            <span class="ascii-demo__mark" aria-hidden="true" set:html={demo.mark} />
            <span>
              <span class="ascii-demo__title">{demo.title}</span>
              <span class="ascii-demo__subtitle">{demo.subtitle}</span>
            </span>
          </span>
          <span class="ascii-demo__note">{demo.note}</span>
          <span class="ascii-demo__chips" aria-label={`${demo.title} examples`}>
            {demo.concrete.map((item) => <span>{item}</span>)}
          </span>
          <pre class="ascii-demo__frame" aria-hidden="true" data-symbol-frame={demo.key}></pre>
          <span class="ascii-demo__status" data-status>idle</span>
        </button>
      ))}
    </div>
  </section>
</BaseLayout>

<script>
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const density = [' ', '.', ':', '+', '*', '#'];

  function renderField(x: number, y: number, tick: number) {
    const rows = ['+------------------------------------------------+'];
    const labels = ['strategy', 'ops', 'agents', 'market'];
    rows.push('| ' + labels.map((label) => label.padEnd(10, ' ')).join('  ') + ' |');
    for (let row = 0; row < 8; row += 1) {
      let line = '| ';
      for (let col = 0; col < 46; col += 1) {
        const dx = col / 46 - x;
        const dy = row / 8 - y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        const wave = Math.sin(col * 0.55 + row * 1.1 + tick * 0.15);
        const index = Math.max(0, Math.min(density.length - 1, Math.floor((1 - dist * 2.5 + wave * 0.35) * density.length)));
        const node = (col + row * 7 + tick) % 31 === 0;
        line += node ? 'o' : density[index];
      }
      line += ' |';
      rows.push(line);
    }
    rows.push('|                 signal: tracking              |');
    rows.push('+------------------------------------------------+');
    return rows.join('\n');
  }

  const stage = document.querySelector('[data-ascii-stage]');
  const field = document.querySelector('[data-ascii-field]');
  let pointer = { x: 0.5, y: 0.5 };
  let tick = 0;

  stage?.addEventListener('pointermove', (event) => {
    const pointerEvent = event as PointerEvent;
    const rect = stage.getBoundingClientRect();
    pointer = {
      x: Math.max(0, Math.min(1, (pointerEvent.clientX - rect.left) / rect.width)),
      y: Math.max(0, Math.min(1, (pointerEvent.clientY - rect.top) / rect.height)),
    };
  });

  function animateStage() {
    if (!prefersReduced && field) {
      tick += 1;
      field.textContent = renderField(pointer.x, pointer.y, tick);
      window.requestAnimationFrame(animateStage);
    }
  }
  animateStage();

  const symbolFrames = document.querySelectorAll('[data-symbol-frame]');

  function emptyGrid(width: number, height: number) {
    return Array.from({ length: height }, () => Array.from({ length: width }, () => ' '));
  }
  function put(grid: string[][], x: number, y: number, char: string) {
    if (grid[y] && grid[y][x] !== undefined) grid[y][x] = char;
  }
  function toText(grid: string[][]) {
    return grid.map((row) => row.join('')).join('\n');
  }
  function drawStrategy(symbolTick: number, active: number) {
    const grid = emptyGrid(30, 10);
    const cx = 15, cy = 5;
    for (let i = 0; i < 32; i += 1) {
      const angle = (i / 32) * Math.PI * 2 + symbolTick * 0.025;
      const r = 2.5 + (i % 4) * 0.9 + active * 0.25;
      put(grid, Math.round(cx + Math.cos(angle) * r * 1.45), Math.round(cy + Math.sin(angle) * r * 0.75), i % 8 === 0 ? '*' : '.');
    }
    const sweep = Math.sin(symbolTick * 0.06) * 7;
    for (let i = -8; i <= 8; i += 1) put(grid, Math.round(cx + i), Math.round(cy - i * 0.28), i === 0 ? 'o' : '-');
    put(grid, Math.round(cx + sweep), cy - 3, '/');
    put(grid, Math.round(cx + sweep) + 1, cy - 3, '-');
    put(grid, Math.round(cx + sweep) + 2, cy - 3, '>');
    put(grid, cx, 1, '^'); put(grid, 27, cy, '>'); put(grid, cx, 9, 'v'); put(grid, 2, cy, '<');
    return toText(grid);
  }
  function drawOperations(symbolTick: number, active: number) {
    const grid = emptyGrid(30, 10);
    for (let x = 3; x < 28; x += 4) {
      for (let y = 2; y < 9; y += 3) {
        const phase = (x + y + symbolTick + active * 4) % 12;
        put(grid, x, y, phase < 6 ? '[' : ']');
        put(grid, x + 1, y, phase < 3 ? ':' : phase < 7 ? '.' : '+');
        put(grid, x + 2, y, phase < 6 ? ']' : '[');
      }
    }
    for (let y = 1; y < 9; y += 2) {
      for (let x = 1; x < 29; x += 1) {
        if ((x + y + symbolTick) % 9 < 4) put(grid, x, y, x % 5 === 0 ? '+' : '-');
      }
    }
    return toText(grid);
  }
  function drawProduct(symbolTick: number, active: number) {
    const grid = emptyGrid(30, 10);
    const cx = 15, cy = 5;
    const chars = ['{', '<', '*', '>', '}'];
    for (let ring = 0; ring < 2; ring += 1) {
      for (let i = 0; i < 20; i += 1) {
        const angle = (i / 20) * Math.PI * 2 + symbolTick * (ring ? -0.025 : 0.035);
        const rx = 5 + ring * 4 + active * 0.35;
        const ry = 2 + ring * 1.2;
        put(grid, Math.round(cx + Math.cos(angle) * rx), Math.round(cy + Math.sin(angle) * ry), chars[(i + ring) % chars.length]);
      }
    }
    put(grid, cx - 2, cy, '{'); put(grid, cx - 1, cy, '<'); put(grid, cx, cy, '*'); put(grid, cx + 1, cy, '>'); put(grid, cx + 2, cy, '}');
    return toText(grid);
  }
  function drawAutomation(symbolTick: number, active: number) {
    const grid = emptyGrid(30, 10);
    const cx = 15, cy = 5;
    const points = [[5,2],[11,1],[20,2],[24,5],[20,8],[10,8],[5,6],[15,5]];
    points.forEach(([x,y], i) => {
      const pulse = (symbolTick + i * 5 + active * 4) % 24;
      put(grid, x, y, pulse < 8 ? '*' : pulse < 15 ? 'o' : '.');
      if (pulse < 13) {
        const mx = Math.round((x + cx) / 2);
        const my = Math.round((y + cy) / 2);
        put(grid, mx, my, pulse < 6 ? '+' : '.');
      }
    });
    put(grid, cx - 1, cy, '>'); put(grid, cx, cy, '*'); put(grid, cx + 1, cy, '_');
    for (let i = 0; i < 18; i += 1) {
      const angle = (i / 18) * Math.PI * 2 - symbolTick * 0.03;
      put(grid, Math.round(cx + Math.cos(angle) * 3), Math.round(cy + Math.sin(angle) * 1.5), i % 6 === 0 ? ':' : '.');
    }
    return toText(grid);
  }
  function drawMarketplace(symbolTick: number, active: number) {
    const grid = emptyGrid(30, 10);
    const left = [8, 5], right = [22, 5], cx = 15, cy = 5;
    for (let i = 0; i < 28; i += 1) {
      const angle = (i / 28) * Math.PI * 2 + symbolTick * 0.025;
      put(grid, Math.round(left[0] + Math.cos(angle) * 4), Math.round(left[1] + Math.sin(angle) * 2.2), i % 7 === 0 ? 'o' : '.');
      put(grid, Math.round(right[0] + Math.cos(-angle) * 4), Math.round(right[1] + Math.sin(-angle) * 2.2), i % 7 === 0 ? 'o' : '.');
    }
    '<==>'.split('').forEach((c, i) => put(grid, 13 + i, cy, c));
    put(grid, cx + Math.round(Math.sin(symbolTick * 0.08) * (2 + active)), cy, '*');
    put(grid, left[0], left[1], '<'); put(grid, right[0], right[1], '>');
    return toText(grid);
  }
  function renderSymbol(kind: string, symbolTick: number, active: number) {
    if (kind === 'strategy') return drawStrategy(symbolTick, active);
    if (kind === 'operations') return drawOperations(symbolTick, active);
    if (kind === 'product') return drawProduct(symbolTick, active);
    if (kind === 'automation') return drawAutomation(symbolTick, active);
    return drawMarketplace(symbolTick, active);
  }

  const demoState = new WeakMap<Element, number>();
  document.querySelectorAll('[data-ascii-demo]').forEach((demo) => {
    demoState.set(demo, 0);
    const status = demo.querySelector('[data-status]');
    demo.addEventListener('click', () => {
      const next = ((demoState.get(demo) ?? 0) + 1) % 4;
      demoState.set(demo, next);
      demo.setAttribute('data-active-step', String(next));
      if (status) status.textContent = ['idle', 'active', 'clear', 'alive'][next];
    });
  });

  let symbolTick = 0;
  function animateSymbols() {
    symbolTick += 1;
    symbolFrames.forEach((frame) => {
      const kind = frame.getAttribute('data-symbol-frame') ?? 'strategy';
      const demo = frame.closest('[data-ascii-demo]');
      const active = demo ? (demoState.get(demo) ?? 0) : 0;
      frame.textContent = renderSymbol(kind, symbolTick, active);
    });
    if (!prefersReduced) window.requestAnimationFrame(animateSymbols);
  }
  animateSymbols();
</script>

<style>
  .ascii-stage { position: relative; overflow: hidden; min-height: 360px; border: 1px solid #222538; border-top-color: rgba(255,255,255,.07); border-radius: 24px; background: radial-gradient(circle at 60% 35%, rgba(99,102,241,.18), transparent 34%), #10131C; box-shadow: 0 18px 70px rgba(0,0,0,.35); }
  .ascii-stage__copy { position: relative; z-index: 2; max-width: 430px; padding: 38px; }
  .ascii-stage__eyebrow, .ascii-demo__status { color: #818CF8; font-size: 10px; font-weight: 800; letter-spacing: .18em; text-transform: uppercase; }
  .ascii-stage h2 { margin: 14px 0; color: #F1F5F9; font-size: clamp(2.25rem, 7vw, 5.5rem); line-height: .95; letter-spacing: -.08em; }
  .ascii-stage p, .ascii-demo__note { color: #94A3B8; line-height: 1.6; }
  .ascii-stage__field { position: absolute; right: -20px; bottom: 20px; margin: 0; color: rgba(165, 180, 252, .72); font-size: clamp(9px, 1.25vw, 14px); line-height: 1.25; letter-spacing: -.08em; text-shadow: 0 0 24px rgba(99,102,241,.32); transition: color .2s ease; user-select: none; }
  .ascii-stage:hover .ascii-stage__field { color: rgba(241,245,249,.88); }
  .ascii-demo { position: relative; min-height: 330px; padding: 24px; text-align: left; border: 1px solid #222538; border-top-color: rgba(255,255,255,.06); border-radius: 18px; background: radial-gradient(circle at 80% 26%, rgba(99,102,241,.12), transparent 30%), #13161F; cursor: pointer; overflow: hidden; transition: transform .2s ease, border-color .2s ease, box-shadow .2s ease; }
  .ascii-demo:hover, .ascii-demo:focus-visible { transform: translateY(-3px); border-color: rgba(99,102,241,.55); box-shadow: 0 16px 42px rgba(0,0,0,.35), 0 0 32px rgba(99,102,241,.10); outline: none; }
  .ascii-demo__header { display: flex; align-items: center; gap: 14px; margin-bottom: 16px; }
  .ascii-demo__mark { display: inline-flex; min-width: 3.8rem; min-height: 2.5rem; align-items: center; justify-content: center; border: 1px solid rgba(99,102,241,.34); border-radius: 12px; color: #A5B4FC; background: rgba(99,102,241,.10); font-weight: 800; box-shadow: inset 0 1px 0 rgba(255,255,255,.06); }
  .ascii-demo__title { display: block; color: #F1F5F9; font-size: 1.05rem; font-weight: 800; margin-bottom: 2px; }
  .ascii-demo__subtitle { display: block; color: #818CF8; font-size: .72rem; font-weight: 800; letter-spacing: .08em; text-transform: uppercase; }
  .ascii-demo__note { display: block; max-width: 72%; font-size: .83rem; margin-bottom: 16px; }
  .ascii-demo__chips { display: flex; flex-wrap: wrap; gap: 6px; max-width: 72%; }
  .ascii-demo__chips span { border: 1px solid rgba(46,51,80,.85); border-radius: 999px; padding: 3px 8px; color: #CBD5E1; background: rgba(11,13,20,.36); font-size: 10px; font-weight: 700; }
  .ascii-demo__frame { position: absolute; right: -8px; bottom: 34px; width: 48%; margin: 0; color: rgba(148,163,184,.68); font-size: 11px; line-height: 1.25; letter-spacing: -.07em; text-align: left; opacity: .88; transition: color .2s ease, transform .2s ease, text-shadow .2s ease, opacity .2s ease; }
  .ascii-demo:hover .ascii-demo__frame, .ascii-demo[data-active-step] .ascii-demo__frame { color: rgba(241,245,249,.82); opacity: 1; text-shadow: 0 0 18px rgba(99,102,241,.28); transform: translateX(-2px); }
  .ascii-demo__status { position: absolute; right: 20px; bottom: 18px; color: #64748B; }
  .ascii-demo[data-active-step="1"] .ascii-demo__mark { color: #F1F5F9; border-color: rgba(129,140,248,.75); }
  .ascii-demo[data-active-step="2"] .ascii-demo__mark { color: #1F9D6B; border-color: rgba(31,157,107,.65); }
  .ascii-demo[data-active-step="3"] .ascii-demo__mark { color: #E0A100; border-color: rgba(224,161,0,.65); }
  @media (max-width: 720px) { .ascii-demo__note, .ascii-demo__chips { max-width: 100%; } .ascii-demo__frame { position: relative; right: auto; bottom: auto; width: 100%; margin-top: 18px; } }
  @media (prefers-reduced-motion: reduce) { .ascii-demo, .ascii-demo__frame { transition: none; } }
</style>
