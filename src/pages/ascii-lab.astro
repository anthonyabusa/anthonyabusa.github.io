---
// #439 ASCII Studio lab: live sliders for every tunable knob on the branch's
// two ASCII surfaces (hero raster + focus-card raster, one shared engine).
// Unlinked from nav;
// exists so tuning happens by feel on a real device instead of by code round-trip.
// Settings persist in localStorage and export as JSON to fold back into the
// engine defaults once a combination is approved.
import BaseLayout from '../layouts/BaseLayout.astro';
import AsciiHeroRaster from '../components/AsciiHeroRaster.astro';
import AsciiFocusCard from '../components/AsciiFocusCard.astro';
import AsciiRasterScript from '../components/AsciiRasterScript.astro';
import { focusAreas } from '../data/focusAreas';

type Knob = { key: string; label: string; min: number; max: number; step: number; d: number };

// Hero source options (Ant direction 2026-07-18: raster-treat the hero).
const heroSources = [
  { idx: 0, label: 'Compass rose' },
  { idx: 1, label: 'AB monogram' },
  { idx: 2, label: 'Orbit mark' },
];

const rasterKnobs: Knob[] = [
  { key: 'speedHover', label: 'Motion · active speed', min: 0.004, max: 0.05, step: 0.001, d: 0.018 },
  { key: 'speedRest', label: 'Motion · resting speed', min: 0.002, max: 0.03, step: 0.001, d: 0.011 },
  { key: 'wobble', label: 'Motion · wobble', min: 0, max: 3, step: 0.05, d: 1 },
  { key: 'sweepStrength', label: 'Intensity · light sweep', min: 0, max: 0.6, step: 0.01, d: 0.2 },
  { key: 'contrast', label: 'Intensity · contrast', min: 0.5, max: 2, step: 0.05, d: 1 },
  { key: 'opacityBase', label: 'Intensity · base glow', min: 0, max: 0.4, step: 0.01, d: 0.1 },
  { key: 'opacityGain', label: 'Intensity · glow gain', min: 0.3, max: 1.5, step: 0.01, d: 0.92 },
  { key: 'alphaCut', label: 'Realism · edge cutoff', min: 0.01, max: 0.2, step: 0.005, d: 0.045 },
  { key: 'letterLevel', label: 'Realism · letters vs texture', min: 1, max: 7, step: 1, d: 5 },
];

const toggles = [
  { group: 'raster', key: 'alwaysOn', label: 'Animate without hover (hero + cards)' },
  { group: 'raster', key: 'ignoreReduceMotion', label: 'Override OS Reduce Motion' },
];

// All five focus areas, same mapping /about uses.
const asciiKeyByFocus = {
  strategy: 'strategy',
  operations: 'operations',
  'product-program-leadership': 'product',
  'ai-automation': 'automation',
  'marketplace-venture-building': 'marketplace',
} as const;
const labCards = focusAreas.map((area) => ({
  area,
  key: asciiKeyByFocus[area.slug as keyof typeof asciiKeyByFocus],
}));
---

<BaseLayout title="ASCII Lab" description="Internal tuning lab for the site's ASCII art surfaces.">
  <!-- Seed the tune object BEFORE the hoisted component modules run: lab
       defaults force motion on (Ant reviews from a phone with OS Reduce Motion
       on), then any saved slider values overlay them. -->
  <script is:inline>
    (function () {
      var DEF = {
        hero: { source: 1 },
        raster: { ignoreReduceMotion: 1, alwaysOn: 1 },
      };
      var saved = {};
      try { saved = JSON.parse(localStorage.getItem('asciiTune.v1') || '{}') || {}; } catch (e) { saved = {}; }
      window.__ASCII_TUNE = {
        hero: Object.assign({}, DEF.hero, saved.hero),
        raster: Object.assign({}, DEF.raster, saved.raster),
      };
    })();
  </script>

  <div class="max-w-3xl mx-auto px-6 pt-28 pb-24">
    <header class="mb-10">
      <p class="text-accent font-mono text-xs tracking-widest uppercase mb-3">Studio · Internal</p>
      <h1 class="text-3xl font-bold text-ink mb-3">ASCII Lab</h1>
      <p class="text-ink-muted text-sm leading-relaxed">
        The hero now uses the same raster treatment as the focus cards: pick its source
        mark below. Changes apply instantly and save to the Studio automatically: tune
        until it feels right, then just say the editing is done. Card links are disabled here.
      </p>
      <div class="mt-5 flex flex-wrap items-center gap-3">
        <button
          type="button"
          data-lab-reset
          class="px-4 py-2 rounded-lg border border-border-strong text-ink-soft text-sm font-medium hover:border-accent transition-colors"
        >Reset to defaults</button>
        <span class="font-mono text-xs text-ink-subtle" data-lab-saved>settings sync on change</span>
      </div>
    </header>

    <div class="mb-10 grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-3">
      {toggles.map((t) => (
        <label class="flex items-center gap-3 text-sm text-ink-soft">
          <input
            type="checkbox"
            data-knob={t.key}
            data-group={t.group}
            class="accent-accent w-4 h-4"
          />
          {t.label}
        </label>
      ))}
    </div>

    <!-- Surface 1: hero raster (same treatment as the cards, hero-scale source) -->
    <section class="mb-6 rounded-2xl border border-border bg-background overflow-hidden">
      <div class="px-5 pt-4 pb-2 flex items-baseline justify-between">
        <h2 class="text-ink font-semibold">Hero raster</h2>
        <span class="text-ink-subtle font-mono text-xs">shares the sliders below</span>
      </div>
      <div class="relative flex justify-center py-6 overflow-x-auto">
        <AsciiHeroRaster />
      </div>
      <div class="px-5 pb-5 flex flex-wrap gap-x-6 gap-y-2">
        {heroSources.map((src) => (
          <label class="flex items-center gap-2 text-sm text-ink-soft">
            <input
              type="radio"
              name="heroSource"
              data-knob="source"
              data-group="hero"
              value={src.idx}
              checked={src.idx === 1}
              class="accent-accent"
            />
            {src.label}
          </label>
        ))}
      </div>
    </section>

    <!-- Surface 2: focus-card raster -->
    <section class="mb-6">
      <h2 class="text-ink font-semibold mb-4">Focus-card raster</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4" data-lab-cards>
        {labCards.map(({ area, key }) => (
          <AsciiFocusCard item={area} asciiKey={key} />
        ))}
      </div>
    </section>

    <div class="space-y-4">
      {rasterKnobs.map((k) => (
        <label class="block">
          <span class="flex items-baseline justify-between text-xs font-mono mb-1">
            <span class="text-ink-soft">{k.label}</span>
            <span class="text-accent-lighter" data-knob-value={`raster.${k.key}`}>{k.d}</span>
          </span>
          <input
            type="range"
            data-knob={k.key}
            data-group="raster"
            min={k.min}
            max={k.max}
            step={k.step}
            value={k.d}
            class="w-full accent-accent"
          />
        </label>
      ))}
    </div>
  </div>

  <AsciiRasterScript />

  <style is:global>
    /* Lab context: production hides card art at rest (hover-reveal, none on
       touch), but here the art IS the thing under review, so keep every lab
       canvas laid out and visible on all devices. */
    [data-lab-cards] .ascii-focus-card__canvas {
      display: block;
      position: relative;
      right: auto;
      bottom: auto;
      width: 100%;
      height: 180px;
      margin-top: 18px;
      opacity: 0.98;
    }
    [data-lab-cards] .ascii-focus-card { min-height: auto; }
    [data-lab-cards] .ascii-focus-card__content { max-width: 100%; }
  </style>

  <script>
    // Panel wiring: every input writes window.__ASCII_TUNE, persists it, and
    // fires 'ascii-tune' so both engines repaint mid-animation.
    type TuneMap = Record<string, Record<string, number>>;
    const tune = (window as unknown as { __ASCII_TUNE: TuneMap }).__ASCII_TUNE;
    const persist = () => {
      try { localStorage.setItem('asciiTune.v1', JSON.stringify(tune)); } catch { /* private mode */ }
    };
    const announce = () => window.dispatchEvent(new Event('ascii-tune'));

    // Server-side capture: debounce-POST every change to the dev server's
    // /api/ascii-tune (astro.config middleware), which lands it on the preview
    // host. The reviewing agent reads it there: nothing to copy or send back.
    const savedBadge = document.querySelector('[data-lab-saved]');
    let saveTimer = 0;
    const pushToStudio = () => {
      window.clearTimeout(saveTimer);
      saveTimer = window.setTimeout(async () => {
        try {
          const r = await fetch('/api/ascii-tune', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify(tune),
          });
          if (savedBadge) savedBadge.textContent = r.ok
            ? `saved to studio ${new Date().toLocaleTimeString()}`
            : 'save failed (not the dev preview?)';
        } catch {
          if (savedBadge) savedBadge.textContent = 'save failed (not the dev preview?)';
        }
      }, 600);
    };

    document.querySelectorAll<HTMLInputElement>('[data-knob]').forEach((input) => {
      const group = input.dataset.group ?? 'flow';
      const key = input.dataset.knob ?? '';
      const isToggle = input.type === 'checkbox';
      const isRadio = input.type === 'radio';
      const readout = document.querySelector(`[data-knob-value="${group}.${key}"]`);
      const saved = tune[group]?.[key];
      if (typeof saved === 'number') {
        if (isToggle) input.checked = !!saved;
        else if (isRadio) input.checked = Number(input.value) === saved;
        else input.value = String(saved);
      }
      const show = () => { if (readout) readout.textContent = input.value; };
      show();
      input.addEventListener('input', () => {
        tune[group] = tune[group] ?? {};
        tune[group][key] = isToggle ? (input.checked ? 1 : 0) : Number(input.value);
        persist();
        show();
        announce();
        pushToStudio();
      });
    });

    // Capture the opening state too, so the studio always holds the settings
    // the review actually ran with, even if no slider is ever moved.
    pushToStudio();

    // Kick both engines once wired: raster alwaysOn needs a first ensureLoop,
    // and the hero autopilot may have been toggled since its module ran.
    announce();

    // The cards are real /work links on the live site; here they are previews.
    document.querySelectorAll<HTMLAnchorElement>('[data-lab-cards] a').forEach((a) => {
      a.addEventListener('click', (e) => e.preventDefault());
    });

    document.querySelector('[data-lab-reset]')?.addEventListener('click', () => {
      try { localStorage.removeItem('asciiTune.v1'); } catch { /* private mode */ }
      window.location.reload();
    });
  </script>
</BaseLayout>
