---
import BaseLayout from '../layouts/BaseLayout.astro';

const demos = [
  {
    key: 'strategy',
    href: '/work/strategy',
    mark: '/->',
    title: 'Strategy',
    subtitle: 'Set direction',
    note: 'Market shape, positioning, tradeoffs, and where effort should go.',
    concrete: ['north star', 'positioning', 'decision logic'],
  },
  {
    key: 'operations',
    href: '/work/operations',
    mark: '[::]',
    title: 'Operations',
    subtitle: 'Tune the machine',
    note: 'Operating rhythm, handoffs, leverage points, metrics, and better flow.',
    concrete: ['gears', 'cadence', 'flow'],
  },
  {
    key: 'product',
    href: '/work/product-program-leadership',
    mark: '{<>}',
    title: 'Product / Program',
    subtitle: 'Iterate to release',
    note: 'Discovery, build, test, ship, learn, and repeatable delivery.',
    concrete: ['discover', 'build/test', 'ship/learn'],
  },
  {
    key: 'automation',
    href: '/work/ai-automation',
    mark: '>*_',
    title: 'AI Automation',
    subtitle: 'Think with machines',
    note: 'Agents, memory, reasoning paths, analytics, and useful automated action.',
    concrete: ['brain', 'memory', 'reasoning'],
  },
  {
    key: 'marketplace',
    href: '/work/marketplace-venture-building',
    mark: '&lt;=&gt;',
    title: 'Stakeholder Networks',
    subtitle: 'Align the network',
    note: 'Stakeholders, hubs, relationships, trust, influence, and coordinated action.',
    concrete: ['hub/spoke', 'alignment', 'influence'],
  },
];
---

<BaseLayout
  title="ASCII Motion Lab"
  description="High-resolution textmode motion directions for Anthony Busa's portfolio symbol and graphics system."
>
  <section class="max-w-6xl mx-auto px-6 pt-32 pb-24">
    <div class="max-w-3xl mb-12">
      <p class="text-[#6366F1] font-mono text-xs tracking-widest uppercase mb-4">Visual system spike</p>
      <h1 class="text-4xl md:text-6xl font-bold text-[#F1F5F9] leading-tight mb-5">ASCII motion lab</h1>
      <p class="text-[#94A3B8] text-lg leading-relaxed">
        This pass moves the symbols from low-res terminal doodles into higher-resolution textmode canvases. The hero is now an ambient signal field, not a literal tracker trying to hit skill labels.
      </p>
    </div>

    <div class="ascii-stage mb-10" data-ascii-stage>
      <canvas class="ascii-stage__canvas" data-hero-canvas width="980" height="430" aria-hidden="true"></canvas>
      <div class="ascii-stage__copy">
        <span class="ascii-stage__eyebrow">hero candidate</span>
        <h2>systems in motion</h2>
        <p>Move your cursor through the field. The graphic responds as an ambient signal layer, not a literal target tracker.</p>
      </div>
    </div>

    <div class="grid md:grid-cols-2 xl:grid-cols-3 gap-5">
      {demos.map((demo) => (
        <a class={`ascii-demo ascii-demo--${demo.key}`} href={demo.href} data-ascii-demo={demo.key} aria-label={`View ${demo.title} work: ${demo.note}`}>
          <canvas class="ascii-demo__canvas" data-symbol-canvas={demo.key} width="420" height="260" aria-hidden="true"></canvas>
          <span class="ascii-demo__content">
            <span class="ascii-demo__header">
              <span class="ascii-demo__mark" aria-hidden="true" set:html={demo.mark} />
              <span>
                <span class="ascii-demo__title">{demo.title}</span>
                <span class="ascii-demo__subtitle">{demo.subtitle}</span>
              </span>
            </span>
            <span class="ascii-demo__note">{demo.note}</span>
            <span class="ascii-demo__chips" aria-label={`${demo.title} examples`}>
              {demo.concrete.map((item) => <span>{item}</span>)}
            </span>
            <span class="ascii-demo__cta">View related work →</span>
          </span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<script>
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const glyphs = ['.', ':', '+', '*', '#'];

  type TextCanvas = {
    canvas: HTMLCanvasElement;
    ctx: CanvasRenderingContext2D;
    cols: number;
    rows: number;
    cw: number;
    ch: number;
  };

  function setupCanvas(canvas: HTMLCanvasElement, cols: number, rows: number): TextCanvas | null {
    const ctx = canvas.getContext('2d');
    if (!ctx) return null;
    const dpr = window.devicePixelRatio || 1;
    const cssWidth = canvas.width;
    const cssHeight = canvas.height;
    canvas.width = Math.floor(cssWidth * dpr);
    canvas.height = Math.floor(cssHeight * dpr);
    canvas.style.width = `${cssWidth}px`;
    canvas.style.height = `${cssHeight}px`;
    ctx.scale(dpr, dpr);
    ctx.font = '10px "JetBrains Mono", ui-monospace, monospace';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    return { canvas, ctx, cols, rows, cw: cssWidth / cols, ch: cssHeight / rows };
  }

  function clear(tc: TextCanvas, alpha = 0.08) {
    tc.ctx.clearRect(0, 0, tc.canvas.width, tc.canvas.height);
    tc.ctx.fillStyle = `rgba(11, 13, 20, ${alpha})`;
    tc.ctx.fillRect(0, 0, Number.parseFloat(tc.canvas.style.width), Number.parseFloat(tc.canvas.style.height));
  }

  function drawChar(tc: TextCanvas, col: number, row: number, char: string, opacity = 0.72, color = '165,180,252') {
    if (col < 0 || row < 0 || col >= tc.cols || row >= tc.rows) return;
    tc.ctx.fillStyle = `rgba(${color}, ${opacity})`;
    tc.ctx.fillText(char, (col + 0.5) * tc.cw, (row + 0.5) * tc.ch);
  }

  function drawLine(tc: TextCanvas, x1: number, y1: number, x2: number, y2: number, char = '.', opacity = 0.55) {
    const steps = Math.max(Math.abs(x2 - x1), Math.abs(y2 - y1), 1);
    for (let i = 0; i <= steps; i += 1) {
      const t = i / steps;
      drawChar(tc, Math.round(x1 + (x2 - x1) * t), Math.round(y1 + (y2 - y1) * t), char, opacity);
    }
  }

  const heroCanvas = document.querySelector<HTMLCanvasElement>('[data-hero-canvas]');
  const hero = heroCanvas ? setupCanvas(heroCanvas, 88, 32) : null;
  const stage = document.querySelector('[data-ascii-stage]');
  let pointer = { x: 0.62, y: 0.42 };
  stage?.addEventListener('pointermove', (event) => {
    const pointerEvent = event as PointerEvent;
    const rect = stage.getBoundingClientRect();
    pointer = {
      x: Math.max(0, Math.min(1, (pointerEvent.clientX - rect.left) / rect.width)),
      y: Math.max(0, Math.min(1, (pointerEvent.clientY - rect.top) / rect.height)),
    };
  });

  function renderHero(tick: number) {
    if (!hero) return;
    clear(hero, 0.02);
    const px = pointer.x * hero.cols;
    const py = pointer.y * hero.rows;
    for (let y = 0; y < hero.rows; y += 1) {
      for (let x = 0; x < hero.cols; x += 1) {
        const dx = x - px;
        const dy = (y - py) * 1.8;
        const dist = Math.sqrt(dx * dx + dy * dy);
        const wave = Math.sin(x * 0.18 + y * 0.34 + tick * 0.025);
        const signal = Math.max(0, 1 - dist / 34) + wave * 0.22;
        if (signal < 0.16 && (x + y + tick) % 19 !== 0) continue;
        const gi = Math.max(0, Math.min(glyphs.length - 1, Math.floor(signal * glyphs.length)));
        drawChar(hero, x, y, glyphs[gi], 0.18 + Math.max(0, signal) * 0.55);
      }
    }
    // designed signal paths, not label tracking
    const centers = [[16, 22], [32, 12], [51, 18], [70, 9]];
    centers.forEach(([x, y], i) => {
      drawLine(hero, Math.round(px), Math.round(py), x, y, i % 2 ? ':' : '.', 0.22);
      drawChar(hero, x, y, i % 2 ? 'o' : '+', 0.64);
    });
  }

  function renderCompass(tc: TextCanvas, tick: number, hover: boolean) {
    clear(tc, 0.03);
    const cx = 57, cy = 18;
    const scale = hover ? 1.06 : 1;
    for (let i = 0; i < 160; i += 1) {
      const a = (i / 160) * Math.PI * 2;
      const r = 13 * scale;
      const x = Math.round(cx + Math.cos(a) * r * 1.25);
      const y = Math.round(cy + Math.sin(a) * r * 0.72);
      drawChar(tc, x, y, i % 20 === 0 ? '+' : '.', i % 20 === 0 ? 0.72 : 0.28);
    }
    drawChar(tc, cx, cy - 12, '^', 0.75);
    drawChar(tc, cx, cy + 12, 'v', 0.45);
    drawChar(tc, cx - 20, cy, '<', 0.45);
    drawChar(tc, cx + 20, cy, '>', 0.55);
    const breathe = Math.sin(tick * 0.018) * 1.5;
    drawLine(tc, cx - 12, cy + 7, cx + 13 + breathe, cy - 7, '/', 0.66);
    drawChar(tc, cx + 14 + Math.round(breathe), cy - 8, '>', 0.94, '241,245,249');
    drawChar(tc, cx, cy, 'o', 0.82, '241,245,249');
  }

  function renderGears(tc: TextCanvas, tick: number, hover: boolean) {
    clear(tc, 0.03);
    const phase = tick * (hover ? 0.045 : 0.028);
    const gears = [[47, 18, 10, 1], [68, 18, 9, -1], [58, 27, 6, -1]];
    gears.forEach(([cx, cy, r, dir]) => {
      for (let i = 0; i < 32; i += 1) {
        const a = (i / 32) * Math.PI * 2 + phase * dir;
        const tooth = i % 4 === 0;
        const rr = r + (tooth ? 2 : 0);
        drawChar(tc, Math.round(cx + Math.cos(a) * rr * 1.15), Math.round(cy + Math.sin(a) * rr * 0.72), tooth ? '+' : '.', tooth ? 0.78 : 0.34);
      }
      for (let i = 0; i < 12; i += 1) {
        const a = (i / 12) * Math.PI * 2 - phase * dir;
        drawLine(tc, cx, cy, Math.round(cx + Math.cos(a) * (r - 2) * 0.85), Math.round(cy + Math.sin(a) * (r - 2) * 0.52), '.', 0.22);
      }
      drawChar(tc, cx, cy, '*', 0.9, '241,245,249');
    });
  }

  function renderLoop(tc: TextCanvas, tick: number, hover: boolean) {
    clear(tc, 0.03);
    const cx = 58, cy = 18;
    const speed = hover ? 0.016 : 0.009;
    for (let i = 0; i < 180; i += 1) {
      const a = (i / 180) * Math.PI * 2 - tick * speed;
      const x = Math.round(cx + Math.cos(a) * 23);
      const y = Math.round(cy + Math.sin(a) * 10);
      drawChar(tc, x, y, i % 30 === 0 ? '+' : '.', i % 30 === 0 ? 0.68 : 0.28);
    }
    const nodes = [[58, 6, '?'], [84, 18, '{}'], [58, 30, '>'], [32, 18, '*']];
    const active = Math.floor(tick / (hover ? 40 : 70)) % nodes.length;
    nodes.forEach(([x, y, c], i) => drawChar(tc, x as number, y as number, String(c), active === i ? 0.95 : 0.55, active === i ? '241,245,249' : '165,180,252'));
    drawChar(tc, 76, 9, '>', 0.75);
    drawChar(tc, 78, 25, 'v', 0.75);
    drawChar(tc, 38, 27, '<', 0.75);
    drawChar(tc, 36, 11, '^', 0.75);
  }

  function renderBrain(tc: TextCanvas, tick: number, hover: boolean) {
    clear(tc, 0.03);
    const cx = 58;
    const pulse = Math.floor(tick / (hover ? 16 : 26)) % 8;
    for (let i = 0; i < 110; i += 1) {
      const a = (i / 110) * Math.PI * 2;
      const leftX = Math.round(cx - 7 + Math.cos(a) * 14);
      const rightX = Math.round(cx + 9 + Math.cos(-a) * 14);
      const y = Math.round(18 + Math.sin(a) * 11);
      drawChar(tc, leftX, y, i % 11 === 0 ? 'o' : '.', i % 11 === 0 ? 0.58 : 0.24);
      drawChar(tc, rightX, y, i % 11 === 0 ? 'o' : '.', i % 11 === 0 ? 0.58 : 0.24);
    }
    const folds = [
      [[45, 12], [52, 10], [57, 14]],
      [[61, 13], [68, 10], [75, 13]],
      [[42, 20], [50, 19], [56, 17]],
      [[62, 21], [70, 19], [78, 22]],
      [[50, 26], [58, 24], [67, 26]],
    ];
    folds.forEach((line, i) => {
      for (let j = 1; j < line.length; j += 1) {
        const [x1, y1] = line[j - 1];
        const [x2, y2] = line[j];
        drawLine(tc, x1, y1, x2, y2, i === pulse % folds.length ? '*' : '.', i === pulse % folds.length ? 0.78 : 0.38);
      }
    });
    drawLine(tc, 58, 9, 58, 28, '|', 0.22);
    drawChar(tc, 58, 19, '*', 0.95, '241,245,249');
  }

  function renderHub(tc: TextCanvas, tick: number, hover: boolean) {
    clear(tc, 0.03);
    const cx = 58, cy = 18;
    const spokes = [[58, 4], [88, 9], [84, 29], [58, 33], [32, 28], [28, 8]];
    spokes.forEach(([x, y], i) => {
      const steps = Math.max(Math.abs(x - cx), Math.abs(y - cy));
      const cycle = (tick * (hover ? 0.28 : 0.18) + i * 5) % (steps * 2);
      const pos = cycle < steps ? cycle : steps * 2 - cycle;
      for (let j = 1; j < steps; j += 1) {
        const active = Math.abs(j - pos) < 1.2;
        drawChar(tc, Math.round(cx + ((x - cx) * j) / steps), Math.round(cy + ((y - cy) * j) / steps), active ? '*' : '.', active ? 0.86 : 0.28);
      }
      drawChar(tc, x, y, 'o', 0.72);
    });
    drawChar(tc, cx - 1, cy, '[', 0.86, '241,245,249');
    drawChar(tc, cx, cy, '*', 0.96, '241,245,249');
    drawChar(tc, cx + 1, cy, ']', 0.86, '241,245,249');
  }

  const renderers: Record<string, (tc: TextCanvas, tick: number, hover: boolean) => void> = {
    strategy: renderCompass,
    operations: renderGears,
    product: renderLoop,
    automation: renderBrain,
    marketplace: renderHub,
  };

  const cards = Array.from(document.querySelectorAll<HTMLAnchorElement>('[data-ascii-demo]')).map((card) => {
    const canvas = card.querySelector<HTMLCanvasElement>('[data-symbol-canvas]');
    const tc = canvas ? setupCanvas(canvas, 116, 38) : null;
    let hover = false;
    card.addEventListener('pointerenter', () => { hover = true; });
    card.addEventListener('pointerleave', () => { hover = false; });
    card.addEventListener('focus', () => { hover = true; });
    card.addEventListener('blur', () => { hover = false; });
    return { key: card.dataset.asciiDemo ?? 'strategy', tc, get hover() { return hover; } };
  });

  let tick = 0;
  function animate() {
    tick += 1;
    renderHero(tick);
    cards.forEach((card) => {
      if (!card.tc) return;
      renderers[card.key]?.(card.tc, tick, card.hover);
    });
    if (!prefersReduced) window.requestAnimationFrame(animate);
  }
  animate();
</script>

<style>
  .ascii-stage { position: relative; overflow: hidden; min-height: 360px; border: 1px solid #222538; border-top-color: rgba(255,255,255,.07); border-radius: 24px; background: radial-gradient(circle at 60% 35%, rgba(99,102,241,.18), transparent 34%), #10131C; box-shadow: 0 18px 70px rgba(0,0,0,.35); }
  .ascii-stage__canvas { position: absolute; inset: 0; width: 100%; height: 100%; opacity: .9; }
  .ascii-stage__copy { position: relative; z-index: 2; max-width: 430px; padding: 38px; }
  .ascii-stage__eyebrow { color: #818CF8; font-size: 10px; font-weight: 800; letter-spacing: .18em; text-transform: uppercase; }
  .ascii-stage h2 { margin: 14px 0; color: #F1F5F9; font-size: clamp(2.25rem, 7vw, 5.5rem); line-height: .95; letter-spacing: -.08em; }
  .ascii-stage p, .ascii-demo__note { color: #94A3B8; line-height: 1.6; }
  .ascii-demo { display: block; position: relative; min-height: 360px; padding: 24px; text-align: left; border: 1px solid #222538; border-top-color: rgba(255,255,255,.06); border-radius: 18px; background: radial-gradient(circle at 78% 34%, rgba(99,102,241,.10), transparent 34%), #13161F; cursor: pointer; overflow: hidden; text-decoration: none; transition: transform .2s ease, border-color .2s ease, box-shadow .2s ease; }
  .ascii-demo:hover, .ascii-demo:focus-visible { transform: translateY(-3px); border-color: rgba(99,102,241,.55); box-shadow: 0 16px 42px rgba(0,0,0,.35), 0 0 32px rgba(99,102,241,.10); outline: none; }
  .ascii-demo__canvas { position: absolute; right: -10px; bottom: 22px; width: 72%; height: 55%; opacity: .92; transition: opacity .2s ease, filter .2s ease, transform .2s ease; }
  .ascii-demo:hover .ascii-demo__canvas, .ascii-demo:focus-visible .ascii-demo__canvas { opacity: 1; filter: drop-shadow(0 0 16px rgba(99,102,241,.22)); transform: translateX(-4px); }
  .ascii-demo__content { position: relative; z-index: 2; display: block; }
  .ascii-demo__header { display: flex; align-items: center; gap: 14px; margin-bottom: 16px; }
  .ascii-demo__mark { display: inline-flex; min-width: 3.8rem; min-height: 2.5rem; align-items: center; justify-content: center; border: 1px solid rgba(99,102,241,.34); border-radius: 12px; color: #A5B4FC; background: rgba(99,102,241,.10); font-weight: 800; box-shadow: inset 0 1px 0 rgba(255,255,255,.06); }
  .ascii-demo:hover .ascii-demo__mark, .ascii-demo:focus-visible .ascii-demo__mark { color: #F1F5F9; border-color: rgba(129,140,248,.75); }
  .ascii-demo__title { display: block; color: #F1F5F9; font-size: 1.05rem; font-weight: 800; margin-bottom: 2px; }
  .ascii-demo__subtitle { display: block; color: #818CF8; font-size: .72rem; font-weight: 800; letter-spacing: .08em; text-transform: uppercase; }
  .ascii-demo__note { display: block; max-width: 72%; font-size: .83rem; margin-bottom: 16px; }
  .ascii-demo__chips { display: flex; flex-wrap: wrap; gap: 6px; max-width: 72%; }
  .ascii-demo__chips span { border: 1px solid rgba(46,51,80,.85); border-radius: 999px; padding: 3px 8px; color: #CBD5E1; background: rgba(11,13,20,.36); font-size: 10px; font-weight: 700; }
  .ascii-demo__cta { position: absolute; left: 0; top: 284px; color: #818CF8; font-size: 11px; font-weight: 800; letter-spacing: .08em; text-transform: uppercase; opacity: .74; }
  @media (max-width: 720px) { .ascii-demo__note, .ascii-demo__chips { max-width: 100%; } .ascii-demo__canvas { position: relative; right: auto; bottom: auto; width: 100%; height: 180px; margin-top: 18px; } .ascii-demo__cta { position: static; display: block; margin-top: 18px; } }
  @media (prefers-reduced-motion: reduce) { .ascii-demo, .ascii-demo__canvas { transition: none; } }
</style>
