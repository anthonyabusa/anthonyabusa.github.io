---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404" description="Page not found.">
  <section class="min-h-screen flex items-center justify-center px-6">
    <div class="text-center max-w-lg">
      <p class="text-[#6366F1] font-mono text-sm tracking-widest uppercase mb-6">
        Error 404
      </p>
      <h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-6 gradient-text">
        Lost the thread.
      </h1>
      <p class="text-lg text-[#94A3B8] mb-10">
        That page does not exist; it may have moved, or it never shipped.
      </p>
      <a
        href="/"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-[#6366F1] text-[#0B0D14] font-semibold text-sm hover:bg-[#4F46E5] transition-colors"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Back home
      </a>
    </div>
  </section>
</BaseLayout>
