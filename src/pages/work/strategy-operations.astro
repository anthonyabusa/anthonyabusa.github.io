---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Strategy & Operations moved" description="Strategy and Operations now have separate filtered work pages.">
  <div class="max-w-3xl mx-auto px-6 pt-32 pb-24">
    <p class="text-[#6366F1] font-mono text-xs tracking-widest uppercase mb-4">Filter updated</p>
    <h1 class="text-4xl font-bold text-[#F1F5F9] mb-5">Strategy and Operations are separate now.</h1>
    <p class="text-[#94A3B8] leading-relaxed mb-8">
      The old combined filter has been split into two more precise views.
    </p>
    <div class="flex flex-wrap gap-3">
      <a href="/work/strategy" class="inline-flex px-5 py-3 rounded-lg bg-[#6366F1] text-[#0B0D14] font-semibold text-sm hover:bg-[#4F46E5] transition-colors">View Strategy</a>
      <a href="/work/operations" class="inline-flex px-5 py-3 rounded-lg border border-[#222538] text-[#94A3B8] text-sm hover:border-[#6366F1] hover:text-[#A5B4FC] transition-colors">View Operations</a>
    </div>
  </div>
</BaseLayout>
