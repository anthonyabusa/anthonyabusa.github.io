---
import BaseLayout from '../layouts/BaseLayout.astro';
import SocialLinks from '../components/SocialLinks.astro';
import AsciiFocusCard from '../components/AsciiFocusCard.astro';
import AsciiRasterScript from '../components/AsciiRasterScript.astro';
import { focusAreas } from '../data/focusAreas';
import { flags } from '../data/flags';

const skills = {
  Business: ['Marketplaces', 'GTM Planning', 'Financial Modeling', 'Operations', 'Fundraising'],
  Technical: ['Python', 'TypeScript', 'Node.js', 'Astro', 'AI Agents', 'APIs'],
  Tools: ['GitHub', 'ClickUp', 'FastAPI', 'Ollama', 'Discord Bots', 'Kraken API'],
};

const asciiKeyByFocus = {
  strategy: 'strategy',
  operations: 'operations',
  'product-program-leadership': 'product',
  'ai-automation': 'automation',
  'marketplace-venture-building': 'marketplace',
  'ai-implementation-enablement': 'enablement',
  'agent-systems-orchestration': 'agents',
  'data-analytics-engineering': 'data',
  'platform-systems-architecture': 'platform',
} as const;
---

<BaseLayout
  title="About"
  description="Anthony Busa: San Diego strategy and operations leader building Navore Market, Metis (a personal AI operating system), and practical automation."
>
  <div class="max-w-5xl mx-auto px-6 pt-32 pb-24">

    <div class="reveal mb-16 flex flex-col md:flex-row md:items-end md:justify-between gap-8">
      <div>
        <p class="text-accent font-mono text-xs tracking-widest uppercase mb-4">About Me</p>
        <h1 class="text-4xl md:text-5xl font-bold text-ink leading-tight">
          Strategist.<br/>Builder.<br/>Transformation Leader.
        </h1>
      </div>
      <img
        src="/anthony-abusa-headshot.jpg"
        alt="Anthony A. Busa"
        class="w-40 h-40 md:w-48 md:h-48 rounded-2xl object-cover border border-border-strong border-t-white/10 shadow-[0_1px_3px_rgba(0,0,0,0.6),0_6px_24px_rgba(0,0,0,0.35)]"
        loading="eager"
      />
    </div>

    <div class="reveal mb-20">
      <div class="max-w-3xl space-y-5 text-ink-muted leading-relaxed">
        <p>
          I'm Anthony Busa, a San Diego-based strategist and operator working at the intersection of business strategy, product execution, and automation.
        </p>
        <p>
          My background spans chemical engineering, a quantitative MBA, corporate strategy, startup operations, and technical program management. That mix helps me move between systems-level technical thinking and the commercial realities that determine whether products and organizations actually work.
        </p>
        <p>
          Today, I help build and scale <a href="/projects/navore-market-aggtech-startup" class="project-link">Navore Market</a>, a local food marketplace connecting local San Diego producers with consumers. That means strategic partnerships, USDA grant execution, product roadmap, analytics, distribution design, producer workflows, and cross-functional execution all have to move together.
        </p>
        <p>
          I'm also building <a href="/projects/personal-ai-operations-system" class="project-link">Metis</a>, a personal AI operating system for agents, memory, governed task lifecycles, and multi-machine orchestration. It is part lab, part operating system, and part proof that small teams can run with much more leverage.
        </p>
        <p>
          Before Navore: led 12 transformation programs at <a href="/experience/johnson-matthey-global-sustainability" class="project-link">Johnson Matthey</a> (global specialty chemicals) driving +37% process efficiency, and founded the North America Government Affairs function there from scratch. Then ran ML/AI integration programs at <a href="/experience/healthrise-ehr-revenue-operations" class="project-link">HealthRise</a>, a healthtech startup spanning EHR software, revenue cycle management, and consulting services.
        </p>
        <div class="pt-4">
          <SocialLinks />
        </div>
      </div>

    </div>

    <div class="mb-20">
      <p class="text-accent font-mono text-xs tracking-widest uppercase mb-3">What I Do</p>
      <h2 class="text-2xl font-bold text-ink mb-8">Areas of Expertise</h2>
      <div class="reveal-group grid sm:grid-cols-2 gap-5">
        {focusAreas.map((item) => (
          <AsciiFocusCard item={item} asciiKey={asciiKeyByFocus[item.slug]} showAscii={flags.asciiArt} />
        ))}
      </div>
      {flags.asciiArt && <AsciiRasterScript />}
    </div>

    <div class="reveal mb-20">
      <p class="text-accent font-mono text-xs tracking-widest uppercase mb-3">Recognition</p>
      <h2 class="text-2xl font-bold text-ink mb-8">Background & Honors</h2>
      <div class="space-y-4 text-ink-muted text-sm leading-relaxed">
        <div class="flex gap-4 items-start">
          <span class="text-accent font-mono text-xs mt-1 shrink-0 w-32">2018</span>
          <p><strong class="text-ink">Forbes 30 Under 30 Scholar</strong>, JPMorgan Chase, Consumer & Retail track. Selected from a national applicant pool.</p>
        </div>
        <div class="flex gap-4 items-start">
          <span class="text-accent font-mono text-xs mt-1 shrink-0 w-32">Education</span>
          <p><strong class="text-ink">Carnegie Mellon University</strong>, MBA, Tepper School (quantitative focus).<br /><strong class="text-ink">Villanova University</strong>, B.S. Chemical Engineering (Student Body President; built student government structure from the ground up).</p>
        </div>
        <div class="flex gap-4 items-start">
          <span class="text-accent font-mono text-xs mt-1 shrink-0 w-32">Interests</span>
          <p>AI systems architecture · backpacking · 3D printing · swimming · strategy writing</p>
        </div>
      </div>
    </div>

    <div class="reveal">
      <p class="text-accent font-mono text-xs tracking-widest uppercase mb-3">Toolkit</p>
      <h2 class="text-2xl font-bold text-ink mb-8">Skills & Tools</h2>
      <div class="space-y-5">
        {Object.entries(skills).map(([category, items]) => (
          <div class="flex flex-wrap items-center gap-3">
            <span class="text-xs text-ink-faint font-mono w-20 shrink-0">{category}</span>
            <div class="flex flex-wrap gap-2">
              {items.map((skill) => <span class="tag">{skill}</span>)}
            </div>
          </div>
        ))}
      </div>
    </div>

  </div>
</BaseLayout>

<style>
  .project-link {
    color: #F1F5F9;
    font-weight: 700;
    text-decoration: underline;
    text-decoration-color: rgba(99, 102, 241, .55);
    text-underline-offset: 4px;
    transition: color .2s ease, text-decoration-color .2s ease;
  }
  .project-link:hover {
    color: #A5B4FC;
    text-decoration-color: #818CF8;
  }
</style>
