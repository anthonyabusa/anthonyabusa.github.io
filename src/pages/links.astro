---
import BaseLayout from '../layouts/BaseLayout.astro';
import { hubLinks, socials } from '../data/links';
---

<BaseLayout
  title="Links"
  description="Anthony Busa's link hub: the full portfolio, projects and apps, writing, and where to connect."
>
  <section class="relative min-h-screen hero-grid overflow-hidden">
    <!-- ambient accent glow, matches the home hero -->
    <div class="absolute top-24 left-1/2 -translate-x-1/2 w-[480px] h-[480px] bg-accent/5 rounded-full blur-3xl pointer-events-none" />

    <div class="relative mx-auto w-full max-w-md px-6 pt-28 pb-16 flex flex-col items-center">
      <!-- Identity -->
      <img
        src="/anthony-abusa-headshot.jpg"
        alt="Anthony A. Busa"
        class="w-24 h-24 rounded-full object-cover border border-border-strong border-t-white/10 shadow-[0_8px_30px_rgba(0,0,0,0.5)] opacity-0 animate-[fadeUp_0.5s_ease_0.05s_forwards]"
        loading="eager"
      />
      <h1 class="mt-5 text-2xl font-bold tracking-tight text-ink opacity-0 animate-[fadeUp_0.5s_ease_0.15s_forwards]">
        Anthony A. Busa
      </h1>
      <p class="mt-2 text-center text-sm text-ink-muted leading-relaxed opacity-0 animate-[fadeUp_0.5s_ease_0.22s_forwards]">
        Strategy &amp; operations · systems builder · San Diego
      </p>

      <!-- Primary link stack -->
      <nav class="reveal-group mt-9 w-full flex flex-col gap-3" aria-label="Featured links">
        {hubLinks.map((link) => (
          <a
            href={link.href}
            target={link.external ? '_blank' : undefined}
            rel={link.external ? 'noopener noreferrer' : undefined}
            class="reveal group card-hover flex items-center gap-4 rounded-xl border border-border bg-surface px-4 py-3.5"
          >
            <span class="ascii-icon shrink-0" aria-hidden="true">{link.icon}</span>
            <span class="min-w-0 flex-1">
              <span class="block text-sm font-semibold text-ink">{link.label}</span>
              {link.sublabel && (
                <span class="block text-xs text-ink-subtle leading-snug">{link.sublabel}</span>
              )}
            </span>
            <svg
              class="shrink-0 text-ink-faint group-hover:text-accent transition-colors"
              aria-hidden="true" width="16" height="16" viewBox="0 0 24 24"
              fill="none" stroke="currentColor" stroke-width="2.5"
            >
              {link.external
                ? <path d="M7 17 17 7M9 7h8v8" />
                : <path d="M5 12h14M12 5l7 7-7 7" />}
            </svg>
          </a>
        ))}
      </nav>

      <!-- Socials -->
      <div class="mt-9 flex items-center gap-5 opacity-0 animate-[fadeUp_0.5s_ease_0.5s_forwards]">
        {socials.map((s) => (
          <a
            href={s.href}
            aria-label={s.label}
            target={s.href.startsWith('mailto') ? undefined : '_blank'}
            rel={s.href.startsWith('mailto') ? undefined : 'noopener noreferrer'}
            class="text-ink-subtle hover:text-accent transition-colors duration-200"
            set:html={s.svg}
          />
        ))}
      </div>

      <a href="/" class="mt-10 font-mono text-xs tracking-widest uppercase text-ink-faint hover:text-accent transition-colors opacity-0 animate-[fadeUp_0.5s_ease_0.6s_forwards]">
        anthonyabusa.com
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>
