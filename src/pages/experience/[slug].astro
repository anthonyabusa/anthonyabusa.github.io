---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FocusAreaLinks from '../../components/FocusAreaLinks.astro';
import projects from '../../data/projects.json';

export function getStaticPaths() {
  return projects.filter((project) => project.slug && project.placement === 'experience').map((project) => ({ params: { slug: project.slug }, props: { project } }));
}
const { project } = Astro.props;
---

<BaseLayout title={project.title} description={project.description}>
  <article class="max-w-5xl mx-auto px-6 pt-32 pb-24">
    <a href="/experience" class="text-xs text-[#64748B] hover:text-[#818CF8] transition-colors">← All experience</a>
    <header class="reveal max-w-4xl mt-10 mb-16">
      <div class="flex flex-wrap gap-2 mb-5">{project.tags.map((tag: string) => <span class="tag">{tag}</span>)}</div>
      <p class="text-[#818CF8] text-xs font-bold uppercase tracking-[0.18em] mb-4">{project.status}</p>
      <h1 class="text-4xl md:text-6xl font-bold text-[#F1F5F9] leading-tight mb-6">{project.title}</h1>
      <p class="text-lg md:text-xl text-[#94A3B8] leading-relaxed max-w-3xl">{project.description}</p>
    </header>
    <section class="reveal grid sm:grid-cols-3 gap-4 mb-16">
      {project.metrics?.map((metric: { value: string; label: string }) => <div class="p-6 rounded-xl border border-[#222538] border-t-white/5 bg-[#13161F]"><p class="text-2xl font-bold text-[#818CF8] mb-2">{metric.value}</p><p class="text-xs text-[#64748B] leading-relaxed">{metric.label}</p></div>)}
    </section>
    <div class="grid md:grid-cols-[1fr_2fr] gap-12">
      <aside class="reveal space-y-7">
        <div><p class="detail-label">Role</p><p class="text-sm text-[#94A3B8]">{project.role}</p></div>
        <div><p class="detail-label">Timeline</p><p class="text-sm text-[#94A3B8]">{project.year}; {project.endYear}</p></div>
        <FocusAreaLinks areaSlugs={project.focusAreas} />
      </aside>
      <div class="space-y-12">
        <section class="reveal detail-section"><p class="detail-label">Context</p><h2>What needed to change</h2><p>{project.challenge}</p></section>
        <section class="reveal detail-section"><p class="detail-label">Leadership</p><h2>How I approached the work</h2><p>{project.approach}</p></section>
        <section class="reveal detail-section"><p class="detail-label">Impact</p><h2>What the work delivered</h2><ul>{project.outcomes?.map((outcome: string) => <li>→ {outcome}</li>)}</ul></section>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .detail-label{color:#818CF8;font-size:10px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;margin-bottom:10px}.detail-section h2{color:#F1F5F9;font-size:1.5rem;font-weight:700;margin-bottom:14px}.detail-section p,.detail-section li{color:#94A3B8;line-height:1.8;font-size:.925rem}.detail-section ul{display:grid;gap:12px}
  :global(.case-label){color:#818CF8;font-size:10px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;margin-bottom:10px}
</style>
