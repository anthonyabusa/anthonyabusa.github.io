---
import BaseLayout from '../../layouts/BaseLayout.astro';
import projects from '../../data/projects.json';

const roles = [
  ...projects.filter((project) => project.placement === 'experience').map((project) => ({
    ...project,
    href: `/experience/${project.slug}`,
    timeline: `${project.year}–${project.endYear}`,
    sortYear: project.year,
  })),
  {
    title: 'Google Cloud Student Innovator',
    role: 'Student Innovator · Google',
    status: 'Part-time undergraduate role',
    description: 'Worked with Google during undergrad as a Student Innovator, gaining early experience at the intersection of technology, community engagement, and emerging cloud products.',
    tags: ['Google Cloud', 'Technology', 'Community', 'Innovation'],
    timeline: 'Undergraduate · Part-time',
    sortYear: 0,
    href: '',
  },
].sort((a, b) => Number(b.sortYear) - Number(a.sortYear));
---

<BaseLayout title="Experience" description="Professional experience across enterprise transformation, healthtech startups, technology, and operations.">
  <div class="max-w-5xl mx-auto px-6 pt-32 pb-24">
    <header class="reveal mb-14">
      <h1 class="text-4xl md:text-5xl font-bold text-[#F1F5F9] mb-4">Experience</h1>
      <p class="text-[#6366F1] font-mono text-xs tracking-widest uppercase mb-4">Professional work</p>
      <p class="text-[#64748B] max-w-xl">Roles where I led transformation, built operating capabilities, and worked across technology, strategy, and execution.</p>
    </header>

    <div class="space-y-6">
      {roles.map((role) => {
        const Tag = role.href ? 'a' : 'article';
        return (
          <Tag href={role.href || undefined} class="reveal group block p-7 rounded-xl border border-[#222538] bg-[#13161F] card-hover">
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3 mb-4">
              <div>
                <h2 class="text-xl font-semibold text-[#F1F5F9] group-hover:text-[#A5B4FC] transition-colors">{role.title}</h2>
                <p class="text-[10px] font-bold uppercase tracking-[0.18em] text-[#818CF8] mt-2">{role.role}</p>
              </div>
              <span class="text-[10px] uppercase tracking-[0.14em] text-[#475569] font-mono whitespace-nowrap">{role.timeline}</span>
            </div>
            <div class="flex flex-wrap gap-2 mb-5">{role.tags.map((tag) => <span class="tag">{tag}</span>)}</div>
            <p class="text-[#64748B] text-sm leading-relaxed max-w-3xl">{role.description}</p>
          </Tag>
        );
      })}
    </div>
  </div>
</BaseLayout>
