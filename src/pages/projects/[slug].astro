---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FocusAreaLinks from '../../components/FocusAreaLinks.astro';
import projects from '../../data/projects.json';

export function getStaticPaths() {
  return projects.filter((project) => project.slug && project.placement !== 'experience').map((project) => ({ params: { slug: project.slug }, props: { project } }));
}
const { project } = Astro.props;
---

<BaseLayout title={project.title} description={project.description}>
  <article class="max-w-5xl mx-auto px-6 pt-32 pb-24">
    <a href="/projects" class="text-xs text-ink-subtle hover:text-accent-light transition-colors">← All projects</a>
    <header class="reveal max-w-4xl mt-10 mb-16">
      <div class="flex flex-wrap gap-2 mb-5">{project.tags.map((tag: string) => <span class="tag">{tag}</span>)}</div>
      <p class="text-accent-light text-xs font-bold uppercase tracking-[0.18em] mb-4">{project.status}</p>
      <h1 class="text-4xl md:text-6xl font-bold text-ink leading-tight mb-6">{project.title}</h1>
      <p class="text-lg md:text-xl text-ink-muted leading-relaxed max-w-3xl">{project.description}</p>
    </header>
    {project.screenshot && (
      <div class="reveal mb-16">
        <img src={project.screenshot} alt={`${project.title} screenshot`} class="w-full rounded-xl border border-border" loading="lazy" />
      </div>
    )}
    <section class="reveal grid sm:grid-cols-3 gap-4 mb-16">
      {/* kind defaults to "quantitative" (big indigo). "qualitative" values (names, statuses,
          tech choices) drop to the card-title tier so large indigo stays reserved for real numbers. */}
      {project.metrics?.map((metric: { value: string; label: string; kind?: 'quantitative' | 'qualitative' }) => <div class="p-6 rounded-xl border border-border border-t-white/5 bg-surface"><p class={metric.kind === 'qualitative' ? 'text-lg font-semibold text-ink mb-2' : 'text-2xl font-bold text-accent-light mb-2'}>{metric.value}</p><p class="text-xs text-ink-muted leading-relaxed">{metric.label}</p></div>)}
    </section>
    <div class="grid md:grid-cols-[1fr_2fr] gap-12">
      <aside class="reveal space-y-7">
        <div><p class="case-label">Role</p><p class="text-sm text-ink-muted">{project.role}</p></div>
        <div><p class="case-label">Timeline</p><p class="text-sm text-ink-muted">{project.year}–{project.endYear ?? 'Present'}</p></div>
        <FocusAreaLinks areaSlugs={project.focusAreas} />
        {project.url && <a href={project.url} target="_blank" rel="noopener noreferrer" class="inline-flex px-5 py-2.5 rounded-lg border border-accent/40 text-sm text-accent-light hover:bg-accent/10 transition-colors">Open project ↗</a>}
      </aside>
      <div class="space-y-12">
        <section class="reveal case-section"><p class="case-label">The challenge</p><h2>What needed to change</h2><p>{project.challenge}</p></section>
        <section class="reveal case-section"><p class="case-label">The approach</p><h2>How I built the system</h2><p>{project.approach}</p></section>
        <section class="reveal case-section"><p class="case-label">The outcome</p><h2>What exists now</h2><ul>{project.outcomes?.map((outcome: string) => <li>→ {outcome}</li>)}</ul></section>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .case-label{color:#818CF8;font-size:10px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;margin-bottom:10px}.case-section h2{color:#F1F5F9;font-size:1.5rem;font-weight:700;margin-bottom:14px}.case-section p,.case-section li{color:#94A3B8;line-height:1.8;font-size:.925rem}.case-section ul{display:grid;gap:12px}
  :global(.case-label){color:#818CF8;font-size:10px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;margin-bottom:10px}
</style>
