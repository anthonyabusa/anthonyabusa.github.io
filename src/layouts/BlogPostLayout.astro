---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
  ogImage?: string;
}

const { title, description, pubDate, updatedDate, tags = [], ogImage } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description} ogImage={ogImage}>
  <article class="max-w-2xl mx-auto px-6 pt-32 pb-24">
    <header class="mb-10">
      <div class="flex flex-wrap gap-2 mb-4">
        {tags.map((tag) => <span class="tag">{tag}</span>)}
      </div>
      <h1 class="text-3xl md:text-4xl font-bold text-[#F1F5F9] leading-tight mb-4">
        {title}
      </h1>
      <p class="text-[#64748B] text-sm">
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
        {updatedDate && (
          <span> · Updated {updatedDate.toLocaleDateString('en-US', { dateStyle: 'medium' })}</span>
        )}
      </p>
    </header>

    <div class="prose prose-invert prose-amber max-w-none
      prose-headings:text-[#F1F5F9] prose-headings:font-semibold
      prose-p:text-[#94A3B8] prose-p:leading-relaxed
      prose-a:text-[#F59E0B] prose-a:no-underline hover:prose-a:underline
      prose-code:text-[#F59E0B] prose-code:bg-[#141928] prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded
      prose-pre:bg-[#141928] prose-pre:border prose-pre:border-[#1E2640]
      prose-blockquote:border-[#F59E0B] prose-blockquote:text-[#64748B]">
      <slot />
    </div>

    <div class="mt-12 pt-8 border-t border-[#1E2640]">
      <a href="/blog" class="text-sm text-[#64748B] hover:text-[#F59E0B] transition-colors">
        &larr; Back to Writing
      </a>
    </div>
  </article>
</BaseLayout>
