---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import RevealScript from '../components/RevealScript.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
}

const {
  title,
  description = 'Anthony Busa: strategy and operations leader building technology-enabled systems across startups, marketplaces, AI workflows, and business strategy.',
  ogImage = '/og-image.png',
  ogType = 'website',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Cloudflare Web Analytics beacon token.
// Get it from: CF dashboard → Analytics & Logs → Web Analytics → Add a site
// (anthonyabusa.com) → copy the token from the snippet. Leave '' to disable.
const CF_BEACON_TOKEN = 'd1c4dab9b8da413a83d1128ac6ffc2f0';

// Person structured data; powers branded search ("Anthony Busa") + rich results.
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Anthony Busa',
  url: 'https://anthonyabusa.com',
  jobTitle: 'Director of Strategy & Operations',
  worksFor: { '@type': 'Organization', name: 'Navore Market' },
  description,
  sameAs: [
    'https://github.com/anthonyabusa',
    'https://linkedin.com/in/anthonyabusa',
  ],
};

// WebSite entity; helps search engines model the site (and enables sitelinks).
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Anthony Busa',
  url: 'https://anthonyabusa.com',
};

// BreadcrumbList; built from the URL path so every non-home page gets accurate
// breadcrumbs with zero per-page wiring (helps Google render breadcrumb rich results).
const crumbSegments = Astro.url.pathname.split('/').filter(Boolean);
const breadcrumbSchema = crumbSegments.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', Astro.site).href },
        ...crumbSegments.map((seg, i) => {
          const isLeaf = i === crumbSegments.length - 1;
          const slugName = decodeURIComponent(seg)
            .replace(/-/g, ' ')
            .replace(/\b\w/g, (c) => c.toUpperCase());
          // Leaf (current page): use the real page title, not the title-cased slug
          // ("Healthrise Ehr ..." reads poorly in Google's breadcrumb). Strip the suffix.
          const leafName = title.replace(/\s*\|\s*Anthony Busa\s*$/i, '').trim();
          return {
            '@type': 'ListItem',
            position: i + 2,
            name: isLeaf && leafName ? leafName : slugName,
            item: new URL('/' + crumbSegments.slice(0, i + 1).join('/') + '/', Astro.site).href,
          };
        }),
      ],
    }
  : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Anthony Busa</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={`${title} | Anthony Busa`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={canonicalURL} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | Anthony Busa`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <meta property="og:site_name" content="Anthony Busa" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image:alt" content="Anthony Busa: strategy and operations leader" />
    <meta name="author" content="Anthony Busa" />
    <meta name="theme-color" content="#0B0D14" />

    <!-- Structured data: Person (branded search / rich results) -->
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    {breadcrumbSchema && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />}

    {CF_BEACON_TOKEN && (
      <script
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${CF_BEACON_TOKEN}"}`}
      />
    )}
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
    <RevealScript />
  </body>
</html>