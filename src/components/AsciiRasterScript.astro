<script>
  // Live-tunable knobs (#439 ascii-lab). Defaults ARE the shipped values;
  // window.__ASCII_TUNE only exists on the lab page, so production behavior is
  // unchanged when it is absent.
  const RT = (k: string, d: number): number => {
    const t = (window as unknown as { __ASCII_TUNE?: { raster?: Record<string, number> } }).__ASCII_TUNE?.raster;
    const v = t ? t[k] : undefined;
    return typeof v === 'number' && Number.isFinite(v) ? v : d;
  };
  const rasterReducedMedia = window.matchMedia('(prefers-reduced-motion: reduce)');
  const prefersReducedAsciiRaster = () => rasterReducedMedia.matches && !RT('ignoreReduceMotion', 0);
  const textureTokens: Record<string, string> = {
    strategy: 'NORTHSTARVECTOR',
    operations: 'GEARSFLOWCADENCE',
    product: 'BUILDTESTSHIP',
    automation: 'BRAINAIMEMORY',
    marketplace: 'HUBSPOKEALIGN',
  };
  const sourcePaths: Record<string, string> = {
    strategy: '/ascii-sources/compass-rose-black.svg',
    operations: '/ascii-sources/icon-gears2.svg',
    product: '/ascii-sources/recycling-symbol.svg',
    automation: '/ascii-sources/brain-outline-lateral.svg',
    marketplace: '/ascii-sources/social-network.svg',
  };
  const sourceImages: Record<string, HTMLImageElement> = {};
  Object.entries(sourcePaths).forEach(([key, path]) => {
    const image = new Image();
    image.decoding = 'async';
    image.src = path;
    sourceImages[key] = image;
  });

  type TextCanvas = {
    canvas: HTMLCanvasElement;
    ctx: CanvasRenderingContext2D;
    cols: number;
    rows: number;
    cw: number;
    ch: number;
  };

  function setupCanvas(canvas: HTMLCanvasElement, cols: number, rows: number): TextCanvas | null {
    const ctx = canvas.getContext('2d');
    if (!ctx) return null;
    const dpr = window.devicePixelRatio || 1;
    const cssWidth = canvas.width;
    const cssHeight = canvas.height;
    canvas.width = Math.floor(cssWidth * dpr);
    canvas.height = Math.floor(cssHeight * dpr);
    canvas.style.width = `${cssWidth}px`;
    canvas.style.height = `${cssHeight}px`;
    ctx.scale(dpr, dpr);
    ctx.font = '8px "JetBrains Mono", ui-monospace, monospace';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    return { canvas, ctx, cols, rows, cw: cssWidth / cols, ch: cssHeight / rows };
  }

  function drawChar(tc: TextCanvas, col: number, row: number, char: string, opacity = 0.72, color = '165,180,252') {
    if (col < 0 || row < 0 || col >= tc.cols || row >= tc.rows) return;
    tc.ctx.fillStyle = `rgba(${color}, ${opacity})`;
    tc.ctx.fillText(char, (col + 0.5) * tc.cw, (row + 0.5) * tc.ch);
  }

  function drawSource(kind: string, ctx: CanvasRenderingContext2D, w: number, h: number, tick: number, hover: boolean) {
    ctx.clearRect(0, 0, w, h);
    const image = sourceImages[kind];
    if (!image || !image.complete || !image.naturalWidth) return;
    const t = tick * (hover ? RT('speedHover', 0.018) : RT('speedRest', 0.011));
    const cx = w * .52;
    const cy = h * .52;
    const fit = Math.min((w * .78) / image.naturalWidth, (h * .78) / image.naturalHeight);
    const drawW = image.naturalWidth * fit;
    const drawH = image.naturalHeight * fit;

    ctx.save();
    ctx.translate(cx, cy);
    ctx.rotate(Math.sin(t) * (kind === 'operations' ? 0.07 : kind === 'product' ? 0.052 : 0.025) * RT('wobble', 1));
    const scale = hover ? 1.06 : 1;
    ctx.scale(scale, scale);
    ctx.shadowColor = 'rgba(5,7,16,.62)';
    ctx.shadowBlur = 18;
    ctx.shadowOffsetX = 13;
    ctx.shadowOffsetY = 15;
    ctx.drawImage(image, -drawW / 2, -drawH / 2, drawW, drawH);
    ctx.restore();

    ctx.globalCompositeOperation = 'source-atop';
    const g = ctx.createLinearGradient(w * .25, h * .18, w * .82, h * .88);
    g.addColorStop(0, 'rgba(255,255,255,1)');
    g.addColorStop(.34, 'rgba(205,216,255,.92)');
    g.addColorStop(.68, 'rgba(108,118,216,.58)');
    g.addColorStop(1, 'rgba(24,28,58,.36)');
    ctx.fillStyle = g;
    ctx.fillRect(0, 0, w, h);
    ctx.globalCompositeOperation = 'source-over';

    ctx.save();
    ctx.globalCompositeOperation = 'lighter';
    const sweep = (Math.sin(t * 1.8) * .5 + .5) * w;
    const hg = ctx.createLinearGradient(sweep - 90, 0, sweep + 90, h);
    hg.addColorStop(0, 'rgba(255,255,255,0)');
    hg.addColorStop(.48, `rgba(255,255,255,${RT('sweepStrength', 0.20)})`);
    hg.addColorStop(1, 'rgba(255,255,255,0)');
    ctx.fillStyle = hg;
    ctx.fillRect(0, 0, w, h);
    ctx.restore();
  }

  const sourceCanvas = document.createElement('canvas');
  sourceCanvas.width = 620;
  sourceCanvas.height = 360;
  const sourceCtx = sourceCanvas.getContext('2d', { willReadFrequently: true });

  // Per-icon brightness normalization (Ant, 2026-07-18: "the compass is barely
  // discernible while the gears are 100% illuminated"). The source SVGs vary
  // wildly in stroke density, so a uniform value ramp renders dense icons hot
  // and sparse icons faint. Compute one gain per icon that lands its p95
  // pixel value on a shared target, cached after first computation.
  const NORM_TARGET = 0.72;
  const iconGain: Record<string, number> = {};
  function gainFor(kind: string, data: Uint8ClampedArray, alphaCut: number): number {
    if (iconGain[kind]) return iconGain[kind];
    const values: number[] = [];
    for (let i = 0; i < data.length; i += 16) { // every 4th pixel
      const a = data[i + 3] / 255;
      if (a < alphaCut) continue;
      const lum = (data[i] * .2126 + data[i + 1] * .7152 + data[i + 2] * .0722) / 255;
      values.push(Math.max(a * .55, lum * a));
    }
    if (values.length < 40) return 1; // image not ready; do not cache
    values.sort((x, y) => x - y);
    const p95 = values[Math.floor(values.length * 0.95)] || 1;
    iconGain[kind] = Math.min(2.4, Math.max(0.45, NORM_TARGET / Math.max(0.05, p95)));
    return iconGain[kind];
  }

  function renderFromSource(tc: TextCanvas, kind: string, tick: number, hover: boolean) {
    tc.ctx.clearRect(0, 0, Number.parseFloat(tc.canvas.style.width), Number.parseFloat(tc.canvas.style.height));
    if (!sourceCtx) return;
    drawSource(kind, sourceCtx, sourceCanvas.width, sourceCanvas.height, tick, hover);
    const data = sourceCtx.getImageData(0, 0, sourceCanvas.width, sourceCanvas.height).data;
    const token = textureTokens[kind] ?? 'SYSTEM';
    const ramp = [' ', '.', ':', '-', '+', '*', '#', '@'];
    const phase = Math.floor(tick / (hover ? 5 : 9));
    const gain = gainFor(kind, data, RT('alphaCut', 0.045));
    for (let row = 0; row < tc.rows; row += 1) {
      for (let col = 0; col < tc.cols; col += 1) {
        const sx = Math.floor((col + 0.5) / tc.cols * sourceCanvas.width);
        const sy = Math.floor((row + 0.5) / tc.rows * sourceCanvas.height);
        const idx = (sy * sourceCanvas.width + sx) * 4;
        const a = data[idx + 3] / 255;
        if (a < RT('alphaCut', 0.045)) continue;
        const lum = (data[idx] * .2126 + data[idx+1] * .7152 + data[idx+2] * .0722) / 255;
        const value = Math.min(1, Math.max(a * .55, lum * a) * gain * RT('contrast', 1));
        const level = Math.max(1, Math.min(ramp.length - 1, Math.floor(value * ramp.length)));
        const textured = level >= Math.round(RT('letterLevel', 5));
        const char = textured ? token[(col + row * 2 + phase) % token.length] : ramp[level];
        const opacity = Math.min(.96, RT('opacityBase', 0.10) + value * RT('opacityGain', 0.92));
        const color = level >= 6 ? '241,245,249' : level >= 4 ? '165,180,252' : '99,102,241';
        drawChar(tc, col, row, char, opacity, color);
      }
    }
  }

  // Hover-load driver: each card shows a static resolved frame at rest, and the
  // animation loop only re-rasterizes the card currently hovered/focused. One
  // card animates at a time instead of every card re-rasterizing every frame
  // (the old always-on loop was the drag). Touch + reduced-motion stay static.
  type RasterCard = { key: string; tc: TextCanvas | null; hovering: boolean; tick: number };

  let asciiRasterRaf = 0;
  function ensureLoop() {
    if (!asciiRasterRaf && !prefersReducedAsciiRaster()) {
      asciiRasterRaf = window.requestAnimationFrame(tickAsciiRaster);
    }
  }
  function tickAsciiRaster() {
    asciiRasterRaf = 0;
    let anyHover = false;
    // alwaysOn (lab toggle): animate every card without needing hover, so the
    // motion can be judged on a touch screen. 0 in production = hover-only.
    const alwaysOn = !!RT('alwaysOn', 0);
    for (const card of cards) {
      if (!card.tc || !(card.hovering || alwaysOn)) continue;
      anyHover = true;
      card.tick += 1;
      renderFromSource(card.tc, card.key, card.tick, card.hovering || alwaysOn);
    }
    if (anyHover) ensureLoop(); // keep ticking only while something is hovered
  }

  // Lab slider changed: repaint every card at its current state and (re)kick
  // the loop so alwaysOn/param changes show immediately. No-op in production.
  window.addEventListener('ascii-tune', () => {
    for (const card of cards) {
      if (card.tc) renderFromSource(card.tc, card.key, card.tick, card.hovering || !!RT('alwaysOn', 0));
    }
    ensureLoop();
  });

  const cards: RasterCard[] = Array.from(
    document.querySelectorAll<HTMLAnchorElement>('[data-ascii-card]'),
  ).map((card) => {
    const canvas = card.querySelector<HTMLCanvasElement>('[data-ascii-raster]');
    const tc = canvas ? setupCanvas(canvas, 168, 54) : null;
    const entry: RasterCard = { key: card.dataset.asciiCard ?? 'strategy', tc, hovering: false, tick: 0 };
    const paintStatic = () => { if (entry.tc) renderFromSource(entry.tc, entry.key, 0, false); };
    const enter = () => { entry.hovering = true; ensureLoop(); };
    const leave = () => { entry.hovering = false; paintStatic(); };
    card.addEventListener('pointerenter', enter);
    card.addEventListener('pointerleave', leave);
    card.addEventListener('focus', enter);
    card.addEventListener('blur', leave);
    // Paint the resting frame once the source image is ready (it loads async).
    const img = sourceImages[entry.key];
    if (img && img.complete && img.naturalWidth) paintStatic();
    else if (img) img.addEventListener('load', paintStatic, { once: true });
    return entry;
  });
</script>
