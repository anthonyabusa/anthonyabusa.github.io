---
const pathname = Astro.url.pathname;

const links = [
  { href: '/apps', label: 'Apps' },
  { href: '/about', label: 'About' },
  { href: '/experience', label: 'Experience' },
  { href: '/projects', label: 'Projects' },
  { href: '/library', label: 'Library' },
  { href: '/blog', label: 'Writing' },
  { href: '/contact', label: 'Contact' },
];
---

<header id="site-nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="text-ink font-semibold tracking-tight hover:text-accent transition-colors">
      Anthony A. Busa
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-8" aria-label="Primary navigation">
      {links.map(({ href, label }) => (
        <a
          href={href}
          aria-current={pathname.startsWith(href) ? 'page' : undefined}
          class:list={[
            "text-sm transition-colors duration-200",
            pathname.startsWith(href)
              ? "text-accent"
              : "text-ink-subtle hover:text-ink"
          ]}
        >
          {label}
        </a>
      ))}
    </nav>

    <!-- Mobile nav toggle -->
    <details class="md:hidden group">
      {/* p-3/-m-3 grows the 22px icon's tap target to 46px (WCAG 2.5.8 / mobile
          guidelines) without moving it visually. */}
      <summary class="list-none cursor-pointer inline-flex p-3 -m-3 text-ink-subtle hover:text-ink" aria-label="Menu">
        <svg aria-hidden="true" class="group-open:hidden" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="4" y1="7" x2="20" y2="7"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="17" x2="20" y2="17"/></svg>
        <svg aria-hidden="true" class="hidden group-open:block" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </summary>
      <nav class="absolute top-full left-3 right-3 bg-[#212435]/95 backdrop-blur-xl border border-border-strong border-t-white/10 rounded-xl p-3 flex flex-col gap-1 shadow-[0_18px_50px_rgba(0,0,0,0.7)]">
        {links.map(({ href, label }) => (
          <a
            href={href}
            class:list={[
              "text-sm font-semibold px-4 py-3 rounded-lg border transition-colors",
              pathname.startsWith(href)
                ? "text-accent-lighter bg-accent/15 border-accent/40"
                : "text-ink-soft border-transparent hover:text-ink hover:bg-white/5 hover:border-white/10"
            ]}
          >
            {label}
          </a>
        ))}
      </nav>
    </details>
  </div>
</header>

<script>
  const nav = document.getElementById('site-nav');
  const onScroll = () => {
    if (window.scrollY > 20) {
      nav?.classList.add('bg-background/90', 'backdrop-blur-md', 'border-b', 'border-border');
    } else {
      nav?.classList.remove('bg-background/90', 'backdrop-blur-md', 'border-b', 'border-border');
    }
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
