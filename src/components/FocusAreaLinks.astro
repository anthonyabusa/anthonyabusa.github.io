---
import { focusAreas } from '../data/focusAreas';

interface Props {
  areaSlugs?: string[];
}

const { areaSlugs = [] } = Astro.props;
const areas = focusAreas.filter((area) => areaSlugs.includes(area.slug));
---

{areas.length > 0 && (
  <div>
    <p class="case-label">Related focus</p>
    <div class="flex flex-wrap gap-2">
      {areas.map((area) => (
        <a
          href={`/work/${area.slug}`}
          class="inline-flex items-center gap-2 rounded-full border border-[#2E3350] bg-[#13161F] px-3 py-2 text-xs text-[#CBD5E1] hover:border-[#6366F1]/60 hover:text-[#A5B4FC] transition-colors"
        >
          <span class="ascii-icon ascii-icon--pill" aria-hidden="true">{area.icon}</span>
          {area.title}
        </a>
      ))}
    </div>
  </div>
)}

<style>
  .case-label {
    color: #818CF8;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .18em;
    text-transform: uppercase;
    margin-bottom: 10px;
  }
</style>
