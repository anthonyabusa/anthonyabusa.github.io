---
import type { FocusArea } from '../data/focusAreas';

interface Props {
  item: FocusArea;
  asciiKey: 'strategy' | 'operations' | 'product' | 'automation' | 'marketplace';
  showAscii?: boolean;
}

const { item, asciiKey, showAscii = true } = Astro.props;
---

<a
  href={`/work/${item.slug}`}
  aria-label={`View ${item.title} projects and experience`}
  class={`ascii-focus-card ascii-focus-card--${asciiKey} reveal group ${showAscii ? '' : 'ascii-focus-card--plain'}`}
  data-ascii-card={asciiKey}
>
  {showAscii && (
    <canvas
      class="ascii-focus-card__canvas"
      data-ascii-raster={asciiKey}
      width="420"
      height="260"
      aria-hidden="true"
    ></canvas>
  )}
  <span class="ascii-focus-card__content">
    <span class="ascii-focus-card__kicker">{item.title === 'Marketplace & Venture Building' ? 'Stakeholder Networks' : item.title}</span>
    <span class="ascii-focus-card__title">{item.title}</span>
    <span class="ascii-focus-card__description">{item.description}</span>
    <span class="ascii-focus-card__cta">
      View related work
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </span>
  </span>
</a>

<style>
  .ascii-focus-card {
    position: relative;
    display: block;
    min-height: 350px;
    padding: 24px;
    overflow: hidden;
    isolation: isolate;
    text-decoration: none;
    border: 1px solid #222538;
    border-top-color: rgba(255, 255, 255, .08);
    border-radius: 18px;
    background:
      radial-gradient(circle at 82% 34%, rgba(129, 140, 248, .12), transparent 31%),
      linear-gradient(145deg, rgba(255, 255, 255, .04), transparent 45%),
      #13161F;
    box-shadow: 0 1px 3px rgba(0,0,0,.6), 0 12px 34px rgba(0,0,0,.28);
    transition: transform .2s ease, border-color .2s ease, box-shadow .2s ease, background .2s ease;
  }
  .ascii-focus-card::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(180deg, rgba(255,255,255,.055), transparent 34%, rgba(0,0,0,.18));
    opacity: .82;
  }
  .ascii-focus-card:hover,
  .ascii-focus-card:focus-visible {
    transform: translateY(-3px);
    border-color: rgba(129, 140, 248, .62);
    box-shadow: 0 18px 48px rgba(0,0,0,.38), 0 0 34px rgba(99,102,241,.13);
    outline: none;
  }
  /* Hidden at rest (Ant, 2026-07-18: the art only earns its place as motion,
     five frozen frames read as noise). Hover/focus fades it in as the
     animation starts; touch and reduced-motion never reveal it, so those
     contexts keep a clean typographic card. The lab forces visibility from JS
     when its alwaysOn toggle is set. */
  .ascii-focus-card__canvas {
    position: absolute;
    right: -12px;
    bottom: 14px;
    width: 78%;
    height: 60%;
    opacity: 0;
    transition: filter .2s ease, transform .2s ease, opacity .35s ease;
  }
  @media (hover: hover) and (prefers-reduced-motion: no-preference) {
    .ascii-focus-card:hover .ascii-focus-card__canvas,
    .ascii-focus-card:focus-visible .ascii-focus-card__canvas {
      opacity: .98;
      filter: drop-shadow(0 0 24px rgba(129,140,248,.30));
      transform: translateX(-5px) scale(1.01);
    }
  }
  .ascii-focus-card__content {
    position: relative;
    z-index: 2;
    display: block;
    max-width: 76%;
  }
  /* No ASCII art: let the copy use the full card and drop the height the art needed. */
  .ascii-focus-card--plain {
    min-height: auto;
  }
  .ascii-focus-card--plain .ascii-focus-card__content {
    max-width: 100%;
  }
  .ascii-focus-card__kicker {
    display: inline-flex;
    margin-bottom: 14px;
    padding: 5px 9px;
    border: 1px solid rgba(99,102,241,.32);
    border-radius: 999px;
    color: #A5B4FC;
    background: rgba(99,102,241,.10);
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: .12em;
    text-transform: uppercase;
  }
  .ascii-focus-card__title {
    display: block;
    margin-bottom: 10px;
    color: #F1F5F9;
    font-size: 1.06rem;
    font-weight: 800;
    line-height: 1.22;
    transition: color .2s ease;
  }
  .ascii-focus-card:hover .ascii-focus-card__title,
  .ascii-focus-card:focus-visible .ascii-focus-card__title {
    color: #A5B4FC; /* --color-accent-lighter: stay on the indigo ramp */
  }
  .ascii-focus-card__description {
    display: block;
    color: #94A3B8;
    font-size: .875rem;
    line-height: 1.62;
  }
  .ascii-focus-card__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 22px;
    color: #818CF8;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: .08em;
    text-transform: uppercase;
    opacity: .78;
    transition: opacity .2s ease, color .2s ease;
  }
  .ascii-focus-card:hover .ascii-focus-card__cta,
  .ascii-focus-card:focus-visible .ascii-focus-card__cta {
    color: #A5B4FC;
    opacity: 1;
  }
  @media (max-width: 720px) {
    .ascii-focus-card { min-height: auto; }
    .ascii-focus-card__content { max-width: 100%; }
    /* Touch never reveals the art, so do not reserve layout for it. */
    .ascii-focus-card__canvas { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .ascii-focus-card,
    .ascii-focus-card__canvas {
      transition: none;
    }
  }
</style>
